{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digital-office.local/schemas/context-envelope.schema.json",
  "title": "Digital Office Context Envelope",
  "description": "A compact, versioned handoff contract. Large evidence and generated outputs stay in artifact storage and travel by reference.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "context_id",
    "run_id",
    "task_id",
    "context_version",
    "cycle_index",
    "from",
    "to",
    "goal",
    "user_intent",
    "summary",
    "current_stage",
    "constraints",
    "acceptance_criteria",
    "facts",
    "source_refs",
    "artifact_refs",
    "decisions",
    "open_questions",
    "omissions",
    "risk_flags",
    "permissions",
    "context_budget",
    "handoff_id",
    "handoff_reason",
    "state_hash"
  ],
  "properties": {
    "kind": {
      "const": "digital-office-context-envelope"
    },
    "version": {
      "const": "2.0.0"
    },
    "context_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_handoff_id": {
      "type": "string"
    },
    "context_version": {
      "type": "integer",
      "minimum": 1
    },
    "cycle_index": {
      "type": "integer",
      "minimum": 0
    },
    "from": {
      "$ref": "#/$defs/actor"
    },
    "to": {
      "$ref": "#/$defs/actor"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "user_intent": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "current_stage": {
      "enum": [
        "context",
        "decide",
        "act",
        "evaluate"
      ]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fact"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "omissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/omission"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "project_id",
        "requested_by",
        "role",
        "allowed_actions"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "requested_by": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "context_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "estimated_tokens",
        "max_tokens",
        "compacted"
      ],
      "properties": {
        "strategy": {
          "enum": [
            "inline",
            "reference",
            "hybrid"
          ]
        },
        "estimated_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "compacted": {
          "type": "boolean"
        },
        "compacted_from_hash": {
          "type": "string"
        }
      }
    },
    "handoff_reason": {
      "type": "string",
      "minLength": 1
    },
    "state_hash": {
      "type": "string",
      "minLength": 12
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "enum": [
            "secretary",
            "agent",
            "skill",
            "human",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "workflow_pack": {
          "type": "string"
        }
      }
    },
    "ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "type",
        "uri",
        "authority",
        "retrievable"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "project_file",
            "company_knowledge",
            "licensed_reference",
            "runtime_artifact",
            "memory_relay",
            "external_link"
          ]
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "authority": {
          "enum": [
            "verified",
            "unverified",
            "licensed",
            "draft",
            "memory_pointer"
          ]
        },
        "retrievable": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fact_id",
        "statement",
        "status",
        "confidence",
        "basis_refs"
      ],
      "properties": {
        "fact_id": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "verified",
            "assumption",
            "uncertain",
            "conflict"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "basis_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "summary",
        "basis_refs"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "basis_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "omission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "reason",
        "retrieval_refs"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "enum": [
            "context_budget",
            "large_artifact",
            "permission_boundary",
            "irrelevant_to_recipient",
            "duplicate"
          ]
        },
        "retrieval_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_id",
        "severity",
        "summary"
      ],
      "properties": {
        "risk_id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "requires_human_review": {
          "type": "boolean"
        }
      }
    }
  }
}
