# Digital Office Web/PWA reverse proxy example.
# Replace office.example.com with the customer's DNS name or internal hostname.

office.example.com {
    encode zstd gzip
    reverse_proxy 127.0.0.1:8787

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy same-origin
        X-Frame-Options DENY
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }
}
