{
  "$schema": "./feishu-team.schema.json",
  "schema_version": "1.0",
  "team_id": "digital-office-research-team",
  "project_id": "replace-with-project-id",
  "chat_name": "研究办公室｜replace-with-project-id",
  "description": "一个研究项目一个群，由 Research Secretary 按需组队",
  "chat_id_env": "RESEARCH_OFFICE_FEISHU_CHAT_ID",
  "secretary_agent_id": "secretary",
  "policy": {"max_hops": 6},
  "agents": [
    {"agent_id": "secretary", "display_name": "Research Secretary", "profile": "office-research-secretary", "app_id_env": "RESEARCH_SECRETARY_APP_ID", "open_id_env": "RESEARCH_SECRETARY_OPEN_ID"},
    {"agent_id": "pm", "display_name": "Principal Investigator", "profile": "office-research-pi", "app_id_env": "RESEARCH_PI_APP_ID", "open_id_env": "RESEARCH_PI_OPEN_ID"},
    {"agent_id": "researcher", "display_name": "Literature Researcher", "profile": "office-literature-researcher", "app_id_env": "RESEARCH_LITERATURE_APP_ID", "open_id_env": "RESEARCH_LITERATURE_OPEN_ID"},
    {"agent_id": "planner", "display_name": "Data Analyst", "profile": "office-data-analyst", "app_id_env": "RESEARCH_ANALYST_APP_ID", "open_id_env": "RESEARCH_ANALYST_OPEN_ID"},
    {"agent_id": "vibe-designer", "display_name": "Methodologist", "profile": "office-methodologist", "app_id_env": "RESEARCH_METHOD_APP_ID", "open_id_env": "RESEARCH_METHOD_OPEN_ID"},
    {"agent_id": "coder", "display_name": "Research Engineer", "profile": "office-research-engineer", "app_id_env": "RESEARCH_ENGINEER_APP_ID", "open_id_env": "RESEARCH_ENGINEER_OPEN_ID"},
    {"agent_id": "writer", "display_name": "Academic Writer", "profile": "office-academic-writer", "app_id_env": "RESEARCH_WRITER_APP_ID", "open_id_env": "RESEARCH_WRITER_OPEN_ID"},
    {"agent_id": "legal", "display_name": "Research Ethics Officer", "profile": "office-research-ethics", "app_id_env": "RESEARCH_ETHICS_APP_ID", "open_id_env": "RESEARCH_ETHICS_OPEN_ID"}
  ]
}
