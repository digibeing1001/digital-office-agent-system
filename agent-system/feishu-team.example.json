{
  "$schema": "./feishu-team.schema.json",
  "schema_version": "1.0",
  "team_id": "digital-office-writer-team",
  "project_id": "replace-with-project-id",
  "chat_name": "写作办公室｜replace-with-project-id",
  "description": "一个写作项目一个群，由秘书按需组建内容团队",
  "chat_id_env": "WRITER_OFFICE_FEISHU_CHAT_ID",
  "secretary_agent_id": "secretary",
  "policy": {"max_hops": 6},
  "agents": [
    {"agent_id": "secretary", "display_name": "Writer Team Secretary", "profile": "writer-team-secretary", "app_id_env": "WRITER_SECRETARY_APP_ID", "open_id_env": "WRITER_SECRETARY_OPEN_ID"},
    {"agent_id": "pm", "display_name": "Writer Team Editor", "profile": "writer-team-editor", "app_id_env": "WRITER_EDITOR_APP_ID", "open_id_env": "WRITER_EDITOR_OPEN_ID"},
    {"agent_id": "researcher", "display_name": "Writer Team Researcher", "profile": "writer-team-researcher", "app_id_env": "WRITER_RESEARCHER_APP_ID", "open_id_env": "WRITER_RESEARCHER_OPEN_ID"},
    {"agent_id": "planner", "display_name": "Writer Team Planner", "profile": "writer-team-planner", "app_id_env": "WRITER_PLANNER_APP_ID", "open_id_env": "WRITER_PLANNER_OPEN_ID"},
    {"agent_id": "vibe-designer", "display_name": "Writer Team Designer", "profile": "writer-team-designer", "app_id_env": "WRITER_DESIGNER_APP_ID", "open_id_env": "WRITER_DESIGNER_OPEN_ID"},
    {"agent_id": "coder", "display_name": "Writer Team Publisher", "profile": "writer-team-publisher", "app_id_env": "WRITER_PUBLISHER_APP_ID", "open_id_env": "WRITER_PUBLISHER_OPEN_ID"},
    {"agent_id": "writer", "display_name": "Writer Team Author", "profile": "writer-team-author", "app_id_env": "WRITER_AUTHOR_APP_ID", "open_id_env": "WRITER_AUTHOR_OPEN_ID"},
    {"agent_id": "legal", "display_name": "Writer Team Legal", "profile": "writer-team-legal", "app_id_env": "WRITER_LEGAL_APP_ID", "open_id_env": "WRITER_LEGAL_OPEN_ID"}
  ]
}
