{
  "kind": "digital-office-digital-employees",
  "version": "1.0.0",
  "model": {
    "entry_agent": "secretary",
    "principle": "The secretary receives work and delegates to product-visible digital employee Agents. Each digital employee may represent a business department owner, but its internal staff are Skills, not subordinate Agents.",
    "levels": [
      "secretary_control_plane",
      "digital_employee_agents",
      "skill_staff_lanes"
    ],
    "forbidden": [
      "department registry as a third Agent layer",
      "legal-contracts Agent",
      "legal-compliance Agent",
      "subordinate Agent staff under a department"
    ]
  },
  "handoff_policy": {
    "context_envelope_required": true,
    "schema": "context-envelope.schema.json",
    "handoff_rule": "Agents exchange compact context envelopes and artifact references. Skills receive the relevant envelope slice and return observations, decisions, risk flags, and artifact refs to the owning digital employee.",
    "truth_sources": [
      "current workflow run state",
      "project knowledge",
      "company knowledge",
      "licensed references",
      "KeyMemory relay summaries"
    ]
  },
  "employees": {
    "secretary": {
      "display_name": "Digital Office Secretary",
      "user_visible_role": "entry, routing, clarification, approvals, final delivery",
      "represents_department_owner": false,
      "agent_id": "secretary",
      "workflow_packs": [
        "office_intake",
        "presentation_delivery",
        "governed_delivery"
      ],
      "skill_staff": [
        "agent-team-staffing",
        "verification-loop"
      ]
    },
    "pm": {
      "display_name": "Digital Office Product Manager",
      "user_visible_role": "product judgment, requirements, prioritization, roadmap",
      "represents_department_owner": true,
      "agent_id": "pm",
      "workflow_packs": [
        "product"
      ],
      "skill_staff": []
    },
    "researcher": {
      "display_name": "Digital Office Researcher",
      "user_visible_role": "evidence gathering, market/domain research, assumption checks",
      "represents_department_owner": true,
      "agent_id": "researcher",
      "workflow_packs": [
        "research"
      ],
      "skill_staff": []
    },
    "planner": {
      "display_name": "Digital Office Planner",
      "user_visible_role": "architecture, plans, feasibility, dependencies",
      "represents_department_owner": true,
      "agent_id": "planner",
      "workflow_packs": [
        "planning"
      ],
      "skill_staff": []
    },
    "vibe-designer": {
      "display_name": "Digital Office Designer",
      "user_visible_role": "GUI, UX, visual direction, prototypes, design review",
      "represents_department_owner": true,
      "agent_id": "vibe-designer",
      "workflow_packs": [
