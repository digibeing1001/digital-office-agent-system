        "frontend-patterns"
      ]
    },
    "coder": {
      "display_name": "Digital Office Coder",
      "user_visible_role": "implementation, debugging, tests, refactoring, deployment",
      "represents_department_owner": true,
      "agent_id": "coder",
      "workflow_packs": [
        "implementation"
      ],
      "skill_staff": [
