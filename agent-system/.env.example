# Digital Office Agent System - Environment Variables
# Copy this file to .env and fill in values

# === Core Paths ===
# Base directory for the agent system (defaults to script location)
# DIGITAL_OFFICE_SYSTEM_HOME=/path/to/digital-office-agent-system/agent-system

# === External Agent Frameworks ===
# Hermes framework home directory
# HERMES_HOME=~/.hermes
# OpenClaw framework home directory
# OPENCLAW_HOME=~/.openclaw

# === Web Server ===
# Host to bind the web server (default: 127.0.0.1)
WEB_HOST=127.0.0.1
# Port for the web server (default: 8787)
WEB_PORT=8787
# Bearer token for /api/* requests. Required for non-loopback binding.
# Generate one with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# DIGITAL_OFFICE_WEB_TOKEN=replace-with-a-random-token

# === Local Models ===
# Ollama server URL (for local model inference)
# OLLAMA_HOST=http://127.0.0.1:11434

# === Data Sharing ===
# Set to "true" to opt into anonymous industry experience sharing
# See agent-system/data-sharing.policy.json for details
INDUSTRY_EXPERIENCE_SHARING=false

# === Logging ===
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Maximum log file size in MB before rotation
LOG_MAX_SIZE_MB=50
# Number of rotated log files to keep
LOG_BACKUP_COUNT=5

# === Agent Requests ===
# Path to agent request configuration file (overrides default config)
# DIGITAL_OFFICE_AGENT_REQUEST_CONFIG=/path/to/agent-requests/config.json
# Auth token for agent request submission
# DIGITAL_OFFICE_AGENT_REQUEST_TOKEN=your-request-token-here

# === Telemetry ===
# Path to data sharing consent file (overrides default location)
# DIGITAL_OFFICE_CONSENT_FILE=/path/to/data-sharing/consent.json
# Auth token for telemetry export
# DIGITAL_OFFICE_TELEMETRY_TOKEN=your-telemetry-token-here

# === Development ===
# Set to "1" to skip virtual environment activation (for dev environments)
# OFFICE_SYSTEM_NO_VENV=1
