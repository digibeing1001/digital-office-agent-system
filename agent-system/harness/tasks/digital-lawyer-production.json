{
  "version": "1.0.0",
  "task_id": "digital-lawyer-production",
  "description": "Verify digital lawyer routing, single digital-employee model, skill-source policy, and human-review guardrails.",
  "roles": [
    "intake",
    "legal"
  ],
  "workflow": "digital_lawyer",
  "gates": [
    {
      "id": "legal_agent_is_single_digital_lawyer",
      "type": "json_path",
      "cwd": "hermes_home",
      "path": "agent-system/agents.registry.json",
      "json_path": [
        "agents",
        "legal",
        "display_name"
      ],
      "equals": "Digital Office Digital Lawyer"
    },
    {
      "id": "legal_workflow_uses_single_digital_lawyer_executor",
      "type": "json_path",
      "cwd": "hermes_home",
      "path": "agent-system/agents.registry.json",
      "json_path": [
        "workflows",
        "legal_contract_review",
        "steps"
      ],
      "equals": [
        "@role:legal"
      ]
    },
    {
      "id": "digital_lawyer_skill_source_policy_records_license_boundary",
      "type": "file_contains",
      "cwd": "hermes_home",
      "path": "agent-system/skills.sources.json",
      "patterns": [
        "claude-for-legal-zh",
        "Legal-Skills-Chinese",
        "CC BY-NC-ND 4.0",
        "do not vendor"
      ]
    },
    {
      "id": "digital_lawyer_local_skill_sources_installed",
      "type": "command",
      "cwd": "hermes_home",
      "command": [
        "agent-system/bin/install-skill-sources"
      ],
      "timeout_seconds": 60
    },
    {
      "id": "digital_lawyer_skill_has_human_review_gate",
      "type": "file_contains",
      "cwd": "hermes_home",
      "path": "skills/digital-lawyer-workflows/SKILL.md",
      "patterns": [
        "internal review draft",
        "human professional review",
        "claude-for-legal-zh",
        "Legal-Skills-Chinese",
        "context envelope"
      ]
    },
    {
      "id": "contract_review_routes_to_digital_lawyer",
      "type": "route",
      "prompt": "请数字律师审查这份供应商合同，重点看责任限制、解除和赔偿条款",
      "expect_agent": "legal",
      "expect_workflow": "legal_contract_review",
      "expect_steps": [
        "legal"
      ]
    },
    {
      "id": "product_compliance_routes_to_digital_lawyer",
      "type": "route",
      "prompt": "产品上线前请数字律师做营销宣传和AI治理合规审查",
      "expect_agent": "legal",
      "expect_workflow": "legal_product_compliance_review",
      "expect_steps": [
        "legal"
      ]
    },
    {
      "id": "no_legal_sub_agents_registered",
      "type": "command",
      "cwd": "hermes_home",
      "command": [
        "bash",
        "-lc",
        "python3 - <<'PY'\nimport json\nfrom pathlib import Path\nreg=json.loads(Path('agent-system/agents.registry.json').read_text(encoding='utf-8'))\nassert 'legal-contracts' not in reg['agents']\nassert 'legal-compliance' not in reg['agents']\nassert 'departments' not in reg\nassert not Path('agent-system/departments.registry.json').exists()\nPY"
      ]
    }
  ]
}
