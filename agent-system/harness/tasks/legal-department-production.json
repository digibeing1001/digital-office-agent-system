{
  "version": "1.0.0",
  "task_id": "legal-department-production",
  "description": "Verify enterprise legal department routing, department registry, skill-source policy, and human-review guardrails.",
  "roles": [
    "intake",
    "legal_intake",
    "legal_contracts",
    "legal_compliance",
    "legal_synthesis"
  ],
  "workflow": "legal_department",
  "gates": [
    {
      "id": "department_registry_declares_legal",
      "type": "json_path",
      "cwd": "hermes_home",
      "path": "agent-system/departments.registry.json",
      "json_path": [
        "departments",
        "legal",
        "lead_agent"
      ],
      "equals": "legal"
    },
    {
      "id": "legal_workflow_uses_capability_lanes",
      "type": "json_path",
      "cwd": "hermes_home",
      "path": "agent-system/agents.registry.json",
      "json_path": [
        "workflows",
        "legal_contract_review",
        "steps"
      ],
      "equals": [
        "@role:legal_intake",
        "@role:legal_contracts",
        "@role:legal_synthesis"
      ]
    },
    {
      "id": "legal_skill_source_policy_records_license_boundary",
      "type": "file_contains",
      "cwd": "hermes_home",
      "path": "agent-system/skills.sources.json",
      "patterns": [
        "claude-for-legal-zh",
        "Legal-Skills-Chinese",
        "CC BY-NC-ND 4.0",
        "do not vendor"
      ]
    },
    {
      "id": "legal_department_skill_has_human_review_gate",
      "type": "file_contains",
      "cwd": "hermes_home",
      "path": "skills/legal-department-workflows/SKILL.md",
      "patterns": [
        "internal review draft",
        "human professional review",
        "claude-for-legal-zh",
        "Legal-Skills-Chinese"
      ]
    },
    {
      "id": "contract_review_routes_to_legal_department",
      "type": "route",
      "prompt": "请法务部审查这份供应商合同，重点看责任限制、解除和赔偿条款",
      "expect_agent": "legal",
      "expect_workflow": "legal_contract_review",
      "expect_steps": [
        "legal",
        "legal-contracts",
        "legal"
      ]
    },
    {
      "id": "product_compliance_routes_to_legal_department",
      "type": "route",
      "prompt": "产品上线前请法务做营销宣传和AI治理合规审查",
      "expect_agent": "legal",
      "expect_workflow": "legal_product_compliance_review",
      "expect_steps": [
        "legal",
        "legal-compliance",
        "legal"
      ]
    }
  ]
}
