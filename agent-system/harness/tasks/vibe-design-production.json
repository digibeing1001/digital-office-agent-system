{
  "version": "1.0.0",
  "task_id": "vibe-design-production",
  "description": "Verify that vibe design has production-ready gates, skill guidance, GUI contract, and secretary policy.",
  "roles": ["design"],
  "workflow": "pm_to_design",
  "gates": [
    {
      "id": "design_skill_exists",
      "type": "file_exists",
      "cwd": "hermes_home",
      "path": "skills/vibe-design-production-harness/SKILL.md"
    },
    {
      "id": "design_skill_has_gates",
      "type": "file_contains",
      "cwd": "hermes_home",
      "path": "skills/vibe-design-production-harness/SKILL.md",
      "patterns": ["Design Gates", "Skeuomorphic Digital Office Notes", "Output Contract"]
    },
    {
      "id": "design_gate_configured",
      "type": "json_path",
      "cwd": "hermes_home",
      "path": "agent-system/harness/production-gates.json",
      "json_path": ["role_gates", "design", "minimum_gates"],
      "contains": "responsive behavior is specified"
    },
    {
      "id": "gui_contract_mentions_harness",
      "type": "file_contains",
      "cwd": "hermes_home",
      "path": "agent-system/docs/gui-contract.md",
      "patterns": ["Production harness", "harness-check", "failed gates"]
    },
    {
      "id": "secretary_knows_design_harness",
      "type": "json_path",
      "cwd": "hermes_home",
      "path": "agent-system/secretary.capabilities.json",
      "json_path": ["production_harness_policy", "role_skill_map", "design"],
      "equals": "vibe-design-production-harness"
    },
    {
      "id": "design_route_stable",
      "type": "route",
      "prompt": "first clarify product requirements then design a GUI prototype",
      "expect_agent": "vibe-designer",
      "expect_workflow": "pm_to_design",
      "expect_steps": ["pm", "vibe-designer"]
    }
  ]
}
