{
  "version": "1.0.0",
  "project_id": "_template",
  "name": "Project Template",
  "status": "template",
  "created_at": null,
  "description": "Copy this template when a GUI user creates a new project.",
  "agent_roster": [
    "pm",
    "researcher",
    "planer",
    "vibe-designer",
    "coder",
    "writer"
  ],
  "human_members": [],
  "access_policy": {
    "human_user_required_for_workflow_start": true,
