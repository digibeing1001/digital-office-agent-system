{
  "version": "1.0.0",
  "kind": "portable-multimodal-pipeline",
  "strategy": "local_first_hybrid",
  "decision": "Use local parsers and small OCR models for text extraction by default. Use cloud or provider VLMs only for semantic image understanding, chart interpretation, screenshot reasoning, or low-confidence local extraction that the user approves.",
  "privacy_default": "local_only",
  "asset_policy": {
    "store_original_file": true,
    "store_extracted_text": true,
    "store_ocr_text": true,
    "store_visual_summary": true,
    "never_replace_source_with_summary": true
  },
  "local_capabilities": {
    "plain_text": {
      "engine": "python_stdlib",
      "status": "builtin",
      "handles": [".md", ".txt", ".json", ".csv"],
      "confidence": "high"
    },
    "docx_text": {
      "engine": "python_stdlib_zip_xml",
      "status": "builtin",
      "handles": [".docx"],
      "confidence": "medium",
      "notes": "Extracts document.xml text without requiring python-docx. Complex tables and comments may need a richer parser later."
    },
    "pdf_text": {
      "engine": "poppler_pdftotext",
      "status": "optional_local_binary",
      "handles": [".pdf"],
      "install_hint": "sudo apt-get install -y poppler-utils",
      "confidence": "high_for_text_pdf"
    },
    "image_ocr": {
      "engine": "rapidocr_onnxruntime_then_tesseract_cli",
      "status": "optional_local_model_pack",
      "handles": [".png", ".jpg", ".jpeg", ".webp", ".bmp", ".tiff"],
      "languages": ["eng", "chi_sim"],
      "install_hint": "agent-system/bin/install-local-models base-ocr-python; optional apt fallback: sudo apt-get install -y tesseract-ocr tesseract-ocr-eng tesseract-ocr-chi-sim",
      "confidence": "medium"
    },
    "enhanced_chinese_ocr": {
      "engine": "paddleocr",
      "status": "optional_local_model_pack",
      "handles": [".png", ".jpg", ".jpeg", ".pdf"],
      "install_hint": "agent-system/bin/install-local-models --pack enhanced-ocr",
      "confidence": "high_for_chinese_documents",
      "notes": "Heavier than Tesseract. Keep optional for privacy-sensitive or Chinese-heavy deployments."
    }
  },
  "vlm_fallback": {
    "default_enabled": false,
    "requires_user_or_admin_approval": true,
    "use_when": [
      "image contains diagrams, UI screenshots, tables, or visual evidence that OCR cannot explain",
      "local OCR confidence is low",
      "the project policy allows external model calls"
    ],
    "store_output_as": "extracted/visual-summary.md",
    "must_include": [
      "model_name",
      "provider",
      "source_file",
      "confidence",
      "limitations"
    ]
  },
  "gui_states": [
    "uploaded",
    "local_extracting",
    "local_extracted",
    "pending_local_model_install",
    "pending_vlm_approval",
    "vlm_extracted",
    "pending_review",
    "approved_for_agent_use",
    "archived"
  ]
}
