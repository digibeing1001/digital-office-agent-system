{
  "version": "0.1.0",
  "kind": "digital-office-identity-access-registry",
  "description": "Identity, team, role, seat, project membership, and access audit contract for multi-human Digital Office deployments.",
  "single_user_experiment_compatible": true,
  "multi_user_required_for_product": true,
  "principles": [
    "Digital Office is a team workspace even when the first deployment has only one real human user.",
    "Human users and Agent workers are separate identities.",
    "Every workflow run records the human user who initiated or approved it and the Agent worker that executed it.",
    "Every licensed industry knowledge query records tenant, deployment, user, project, Agent, workflow run, knowledge pack, entitlement, and decision.",
    "Support access is off by default and must be time-limited, admin-approved, and fully audited."
  ],
  "identity_types": {
    "human_user": {
      "examples": [
        "owner",
        "enterprise_admin",
        "project_manager",
        "professional_reviewer",
        "member",
        "viewer"
      ],
      "source_of_truth": "product_backend_or_enterprise_identity_provider"
    },
    "agent_worker": {
      "examples": [
        "secretary",
        "pm",
        "researcher",
        "coder",
        "writer"
      ],
      "source_of_truth": "agent-system/agents.registry.json"
    },
    "support_operator": {
      "examples": [
        "provider_support_engineer",
        "solution_designer"
      ],
      "source_of_truth": "provider_backend"
    }
  },
  "auth_methods_reserved": [
    "local_admin_bootstrap",
    "email_magic_link",
    "password_plus_mfa",
    "enterprise_sso_oidc",
    "enterprise_saml",
    "offline_signed_admin_token",
    "service_account_token"
  ],
  "roles": {
    "owner": {
      "scope": "tenant",
      "can_manage_billing": true,
      "can_manage_users": true,
      "can_manage_entitlements": true,
      "can_manage_data_sharing": true,
      "can_install_solutions": true
    },
    "enterprise_admin": {
      "scope": "tenant",
      "can_manage_users": true,
      "can_manage_projects": true,
      "can_manage_connectors": true,
      "can_manage_entitlements": true,
      "can_approve_updates": true
    },
    "project_manager": {
      "scope": "project",
      "can_create_workflows": true,
      "can_assign_agents": true,
      "can_approve_project_knowledge": true
    },
    "professional_reviewer": {
      "scope": "project_or_domain",
      "can_approve_domain_outputs": true,
      "human_review_required_for": [
        "legal_opinion",
        "tax_filing_advice",
        "accounting_conclusion",
        "regulated_professional_output"
      ]
    },
    "member": {
      "scope": "project",
      "can_run_workflows": true,
      "can_upload_project_knowledge": true
    },
    "viewer": {
      "scope": "project",
      "can_read_outputs": true
    }
  },
  "seat_policy": {
    "seat_types": [
      "human_full",
      "human_limited",
      "agent_worker",
      "support_operator",
      "service_account"
    ],
    "billing_note": "Agent worker seats can be priced separately from human seats. Licensed industry knowledge can also enforce named-user or query-quota entitlements."
  },
  "project_membership_contract": {
    "member_fields": [
      "user_id",
      "display_name",
      "role",
      "status",
      "joined_at"
    ],
    "project_role_values": [
      "project_manager",
      "professional_reviewer",
      "member",
      "viewer"
    ],
    "agent_delegation": {
      "description": "A human user may delegate a task to an Agent only when the user has project permission and the Agent is on the project roster.",
      "required_claims": [
        "user_id",
        "project_id",
        "agent_id",
        "workflow_run_id",
        "delegation_reason"
      ]
    }
  },
  "knowledge_access_identity": {
    "required_claims": [
      "tenant_id",
      "deployment_id",
      "user_id",
      "user_role",
      "project_id",
      "agent_id",
      "workflow_run_id",
      "source_class",
      "source_id",
      "mount_id"
    ],
    "additional_claims_for_paid_industry_knowledge": [
      "knowledge_pack_id",
      "entitlement_id",
      "license_sku",
      "inside_digital_office_session_id"
    ],
    "deny_when_missing_claims": true
  },
  "audit_log_contract": {
    "append_only": true,
    "events": [
      "user_login",
      "project_member_added",
      "agent_delegated",
      "workflow_started",
      "workflow_approved",
      "knowledge_source_mounted",
      "licensed_knowledge_queried",
      "connector_synced",
      "support_access_granted",
      "support_access_revoked"
    ],
    "retention_policy": "Configurable per enterprise; default keep locally and mirror minimal access metadata to provider backend only when needed for licensing and support."
  },
  "gui_surfaces": [
    "Team Members",
    "Roles and Permissions",
    "Project Members",
    "Agent Delegation",
    "Knowledge Access Logs",
    "Support Access",
    "Seat and Entitlement Usage"
  ],
  "backend_api_reserved": [
    "GET /tenants/{tenant_id}/users",
    "POST /tenants/{tenant_id}/users/invite",
    "PATCH /tenants/{tenant_id}/users/{user_id}/role",
    "POST /projects/{project_id}/members",
    "POST /workflow-runs",
    "POST /knowledge-access/authorize",
    "POST /knowledge-access/log",
    "GET /audit/events"
  ]
}
