#!/usr/bin/env python3
from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import re
import shlex
import subprocess
import sys
from pathlib import Path
from typing import Any


if hasattr(sys.stdout, "reconfigure"):
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")
if hasattr(sys.stderr, "reconfigure"):
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")


TEXT_EXTS = {".md", ".txt", ".json", ".yaml", ".yml", ".py", ".sh", ".ts", ".tsx", ".js", ".jsx", ".css", ".html"}
SKIP_DIRS = {".git", "__pycache__", "node_modules", "reports"}


def agent_system_root() -> Path:
    return Path(__file__).resolve().parents[1]


def hermes_home() -> Path:
    return agent_system_root().parent


def read_json(path: Path) -> Any:
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def write_json(path: Path, data: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        json.dump(data, handle, ensure_ascii=False, indent=2, sort_keys=True)
        handle.write("\n")


def resolve_path(value: str, base: Path) -> Path:
    path = Path(value).expanduser()
    if path.is_absolute():
        return path
    return base / path


def cwd_for(gate: dict[str, Any]) -> Path:
    cwd = gate.get("cwd", "hermes_home")
    if cwd == "agent_system":
        return agent_system_root()
    if cwd == "hermes_home":
        return hermes_home()
    return resolve_path(str(cwd), hermes_home())


def wsl_path(path: Path) -> str:
    resolved = path.resolve()
    drive = resolved.drive.rstrip(":").lower()
    if drive:
        rest = resolved.as_posix().split(":", 1)[1]
        return f"/mnt/{drive}{rest}"
    return resolved.as_posix()


def executable_command(command: list[Any], cwd: Path) -> list[str]:
    items = [str(item) for item in command]
    if not items:
        return items
    if os.name != "nt":
        return items
    if items[0] == "bash":
        wsl_cwd = shlex.quote(wsl_path(cwd))
        wsl_hermes_home = shlex.quote(wsl_path(hermes_home()))
        if len(items) >= 3 and items[1] == "-lc":
            shell = items[2]
        else:
            shell = shlex.join(items)
        return ["wsl", "-e", "bash", "-lc", f"cd {wsl_cwd} && export HERMES_HOME={wsl_hermes_home} && {shell}"]
    if items[0] == "python3":
        items[0] = sys.executable
        return items
    first = Path(items[0])
    candidate = first if first.is_absolute() else cwd / first
    if not candidate.exists() or candidate.suffix:
        return items
    try:
        first_line = candidate.read_text(encoding="utf-8", errors="replace").splitlines()[0]
    except (OSError, IndexError):
        return items
    if "python" in first_line:
        return [sys.executable, str(candidate), *items[1:]]
    if "bash" in first_line:
        return ["bash", str(candidate), *items[1:]]
    return items


def decode_process_output(value: bytes | str | None) -> str:
    """Decode native output, including UTF-16LE emitted by wsl.exe on Windows."""
    if value is None:
        return ""
    if isinstance(value, str):
        return value
    if not value:
        return ""
    if value.startswith((b"\xff\xfe", b"\xfe\xff")):
        encoding = "utf-16"
    else:
        sample = value[:512]
        odd_nuls = sample[1::2].count(0)
        even_nuls = sample[0::2].count(0)
        pairs = max(1, len(sample) // 2)
        if odd_nuls / pairs > 0.2:
            encoding = "utf-16-le"
        elif even_nuls / pairs > 0.2:
            encoding = "utf-16-be"
        else:
            encoding = "utf-8"
    return value.decode(encoding, errors="replace").replace("\x00", "")


def list_tasks() -> list[Path]:
    return sorted((agent_system_root() / "harness" / "tasks").glob("*.json"))


def load_task(task: str) -> tuple[Path, dict[str, Any]]:
    tasks = list_tasks()
    if task == "all":
        raise ValueError("load_task does not accept all")
    direct = Path(task)
    candidates = [direct] if direct.exists() else []
    candidates.extend(path for path in tasks if path.stem == task or read_json(path).get("task_id") == task)
    if not candidates:
        valid = ", ".join(path.stem for path in tasks)
        print(f"harness-runner: unknown task {task!r}. Valid tasks: {valid}", file=sys.stderr)
        raise SystemExit(2)
    path = candidates[0]
    return path, read_json(path)


def command_gate(gate: dict[str, Any]) -> dict[str, Any]:
    command = gate.get("command", [])
    if not isinstance(command, list) or not command:
        return {"status": "error", "summary": "command gate requires a non-empty command list"}
    timeout_seconds = int(gate.get("timeout_seconds", 120))
    cwd = cwd_for(gate)
    environment = {
        **os.environ,
        "HERMES_HOME": str(hermes_home()),
        "PYTHONIOENCODING": "utf-8",
    }
    try:
        proc = subprocess.run(
            executable_command(command, cwd),
            cwd=cwd,
            capture_output=True,
            env=environment,
            timeout=timeout_seconds,
        )
    except FileNotFoundError as exc:
        return {
            "status": "error",
            "summary": f"command executable not found: {exc.filename}",
            "returncode": None,
            "stdout": "",
            "stderr": str(exc)[-4000:],
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "status": "error",
            "summary": f"command timed out after {timeout_seconds}s",
            "returncode": None,
            "stdout": decode_process_output(exc.stdout)[-4000:],
            "stderr": decode_process_output(exc.stderr)[-4000:],
        }
    stdout = decode_process_output(proc.stdout)
    stderr = decode_process_output(proc.stderr)
    return {
        "status": "success" if proc.returncode == 0 else "error",
        "summary": "command passed" if proc.returncode == 0 else f"command failed with exit {proc.returncode}",
        "returncode": proc.returncode,
        "stdout": stdout[-4000:],
        "stderr": stderr[-4000:],
    }


def json_valid_gate(gate: dict[str, Any]) -> dict[str, Any]:
    base = cwd_for(gate)
    patterns = gate.get("patterns", [])
    files: list[Path] = []
    for pattern in patterns:
        files.extend(base.glob(str(pattern)))
    errors = []
    for path in sorted(set(files)):
        try:
            read_json(path)
        except Exception as exc:
            errors.append(f"{path}: {exc}")
    return {
        "status": "success" if not errors else "error",
        "summary": f"validated {len(files)} JSON files" if not errors else f"{len(errors)} JSON files failed",
        "errors": errors,
    }


def file_exists_gate(gate: dict[str, Any]) -> dict[str, Any]:
    path = resolve_path(str(gate.get("path", "")), cwd_for(gate))
    ok = path.exists()
    return {"status": "success" if ok else "error", "summary": f"{path} exists" if ok else f"{path} missing"}


def file_contains_gate(gate: dict[str, Any]) -> dict[str, Any]:
    path = resolve_path(str(gate.get("path", "")), cwd_for(gate))
    patterns = [str(item) for item in gate.get("patterns", [])]
    if not path.exists():
        return {"status": "error", "summary": f"{path} missing"}
    text = path.read_text(encoding="utf-8", errors="replace")
    missing = [pattern for pattern in patterns if pattern not in text]
    return {
        "status": "success" if not missing else "error",
        "summary": f"{path} contains required text" if not missing else f"{path} missing required text",
        "missing": missing,
    }


def json_path(data: Any, path: list[str]) -> Any:
    current = data
    for item in path:
        if isinstance(current, dict):
            current = current[item]
        elif isinstance(current, list):
            current = current[int(item)]
        else:
            raise KeyError(item)
    return current


def json_path_gate(gate: dict[str, Any]) -> dict[str, Any]:
    try:
        path = resolve_path(str(gate.get("path", "")), cwd_for(gate))
        data = read_json(path)
        value = json_path(data, [str(item) for item in gate.get("json_path", [])])
        if "equals" in gate:
            ok = value == gate["equals"]
        elif "contains" in gate:
            ok = gate["contains"] in value
        else:
            ok = bool(value)
        return {
            "status": "success" if ok else "error",
            "summary": f"json path passed: {gate.get('json_path')}" if ok else f"json path failed: {gate.get('json_path')}",
            "value": value,
        }
    except (FileNotFoundError, json.JSONDecodeError, KeyError, IndexError, TypeError) as exc:
        return {
            "status": "error",
            "summary": f"json_path_gate failed: {exc}",
            "value": None,
        }


def iter_text_files(paths: list[str], base: Path) -> list[Path]:
    files: list[Path] = []
    for item in paths:
        path = resolve_path(item, base)
        if path.is_file():
            files.append(path)
        elif path.is_dir():
            for root, dirs, names in os.walk(path):
                dirs[:] = [name for name in dirs if name not in SKIP_DIRS]
                for name in names:
                    candidate = Path(root) / name
                    if candidate.suffix in TEXT_EXTS:
                        files.append(candidate)
    return files


def regex_absent_gate(gate: dict[str, Any]) -> dict[str, Any]:
    base = cwd_for(gate)
    pattern = re.compile(str(gate.get("pattern", "")), re.IGNORECASE)
    hits: list[str] = []
    for path in iter_text_files([str(item) for item in gate.get("paths", ["."])], base):
        text = path.read_text(encoding="utf-8", errors="ignore")
        if pattern.search(text):
            hits.append(str(path.relative_to(base) if path.is_relative_to(base) else path))
            if len(hits) >= int(gate.get("max_hits", 20)):
                break
    return {
        "status": "success" if not hits else "error",
        "summary": "no forbidden regex hits" if not hits else f"forbidden regex matched {len(hits)} files",
        "hits": hits,
    }


def route_gate(gate: dict[str, Any]) -> dict[str, Any]:
    router = hermes_home() / "scripts" / "agent-router"
    try:
        proc = subprocess.run(
            executable_command([str(router), "--route-json", str(gate.get("prompt", ""))], hermes_home()),
            text=True,
            encoding="utf-8",
            errors="replace",
            capture_output=True,
            env={**os.environ, "HERMES_HOME": str(hermes_home())},
        )
    except OSError as exc:
        return {"status": "error", "summary": f"route command failed to start: {exc}", "stderr": str(exc)}
    if proc.returncode != 0:
        return {"status": "error", "summary": f"route command failed with exit {proc.returncode}", "stderr": proc.stderr}
    try:
        data = json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        return {"status": "error", "summary": f"route command returned invalid JSON: {exc}", "stdout": proc.stdout[-4000:], "stderr": proc.stderr[-4000:]}
    failures = []
    for key in ("agent", "workflow", "steps"):
        expected_key = f"expect_{key}"
        if expected_key in gate and data.get(key) != gate[expected_key]:
            failures.append(f"{key}: expected {gate[expected_key]!r}, got {data.get(key)!r}")
    return {
        "status": "success" if not failures else "error",
        "summary": "route expectation passed" if not failures else "route expectation failed",
        "route": data,
        "failures": failures,
    }


GATE_RUNNERS = {
    "command": command_gate,
    "json_valid": json_valid_gate,
    "file_exists": file_exists_gate,
    "file_contains": file_contains_gate,
    "json_path": json_path_gate,
    "regex_absent": regex_absent_gate,
    "route": route_gate,
}


def progress(message: str) -> None:
    """Emit machine-safe progress without corrupting the JSON report on stdout."""
    print(f"[harness] {message}", file=sys.stderr, flush=True)


def run_gate(gate: dict[str, Any]) -> dict[str, Any]:
    runner = GATE_RUNNERS.get(str(gate.get("type", "")))
    if not runner:
        return {"status": "error", "summary": f"unknown gate type: {gate.get('type')}"}
    started = dt.datetime.now(dt.timezone.utc)
    try:
        result = runner(gate)
    except Exception as exc:
        result = {
            "status": "error",
            "summary": f"gate raised {type(exc).__name__}: {exc}",
        }
    finished = dt.datetime.now(dt.timezone.utc)
    return {
        "gate_id": gate.get("id", ""),
        "type": gate.get("type", ""),
        "duration_ms": int((finished - started).total_seconds() * 1000),
        **result,
    }


def run_task(path: Path, task: dict[str, Any]) -> dict[str, Any]:
    started = dt.datetime.now(dt.timezone.utc)
    task_id = str(task.get("task_id", path.stem))
    gates = list(task.get("gates", []))
    progress(f"task {task_id} started ({len(gates)} gates)")
    gate_results = []
    for index, gate in enumerate(gates, start=1):
        gate_id = str(gate.get("id", f"gate-{index}"))
        progress(f"task {task_id} gate {index}/{len(gates)} {gate_id} started")
        result = run_gate(gate)
        gate_results.append(result)
        progress(
            f"task {task_id} gate {index}/{len(gates)} {gate_id} "
            f"{result.get('status')} ({result.get('duration_ms', 0)} ms)"
        )
    status = "success" if all(item.get("status") == "success" for item in gate_results) else "error"
    finished = dt.datetime.now(dt.timezone.utc)
    duration_ms = int((finished - started).total_seconds() * 1000)
    progress(f"task {task_id} {status} ({duration_ms} ms)")
    return {
        "task_id": task_id,
        "task_file": str(path),
        "status": status,
        "started_at": started.isoformat(),
        "finished_at": finished.isoformat(),
        "duration_ms": duration_ms,
        "roles": task.get("roles", []),
        "workflow": task.get("workflow", ""),
        "gates": gate_results,
    }


def write_report(report: dict[str, Any]) -> Path:
    stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%d%H%M%S")
    task_id = str(report.get("task_id", "all")).replace("/", "-")
    path = agent_system_root() / "harness" / "reports" / f"{stamp}-{task_id}.json"
    write_json(path, report)
    return path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--list", action="store_true")
    parser.add_argument("--task", default="all")
    parser.add_argument("--no-write", action="store_true")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    if args.list:
        for path in list_tasks():
            task = read_json(path)
            print(f"{task.get('task_id', path.stem)}\t{task.get('description', '')}")
        return 0

    started = dt.datetime.now(dt.timezone.utc)
    task_paths = list_tasks() if args.task == "all" else [load_task(args.task)[0]]
    reports = []
    for path in task_paths:
        reports.append(run_task(path, read_json(path)))
    finished = dt.datetime.now(dt.timezone.utc)
    aggregate = {
        "task_id": args.task,
        "status": "success" if all(report["status"] == "success" for report in reports) else "error",
        "started_at": started.isoformat(),
        "finished_at": finished.isoformat(),
        "duration_ms": int((finished - started).total_seconds() * 1000),
        "task_counts": {
            "total": len(reports),
            "passed": sum(report["status"] == "success" for report in reports),
            "failed": sum(report["status"] != "success" for report in reports),
        },
        "reports": reports,
    }
    if not args.no_write:
        aggregate["report_path"] = str(write_report(aggregate))
    print(json.dumps(aggregate, ensure_ascii=False, indent=2, sort_keys=True))
    return 0 if aggregate["status"] == "success" else 1


if __name__ == "__main__":
    raise SystemExit(main())
