#!/usr/bin/env python3
"""Provider-neutral direct model API gateway for Digital Office."""

from __future__ import annotations

import argparse
import json
import os
import random
import socket
import stat
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any


RETRYABLE_STATUS = {408, 429, 502, 503, 504}
RUNTIME_MODES = {"host", "direct_api", "auto"}


class GatewayError(RuntimeError):
    def __init__(self, message: str, *, code: str = "gateway_error", status: int = 2) -> None:
        super().__init__(message)
        self.code = code
        self.status = status


def system_root() -> Path:
    configured = os.environ.get("DIGITAL_OFFICE_SYSTEM_HOME")
    return Path(configured).expanduser().resolve() if configured else Path(__file__).resolve().parents[1]


def read_json(path: Path) -> dict[str, Any]:
    try:
        with path.open("r", encoding="utf-8") as handle:
            value = json.load(handle)
    except FileNotFoundError as exc:
        raise GatewayError(f"configuration file not found: {path}", code="config_missing") from exc
    except json.JSONDecodeError as exc:
        raise GatewayError(f"invalid JSON configuration: {path}: {exc}", code="config_invalid") from exc
    if not isinstance(value, dict):
        raise GatewayError(f"configuration must be a JSON object: {path}", code="config_invalid")
    return value


def write_json_private(path: Path, value: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    with temporary.open("w", encoding="utf-8") as handle:
        json.dump(value, handle, ensure_ascii=False, indent=2, sort_keys=True)
        handle.write("\n")
    os.chmod(temporary, stat.S_IRUSR | stat.S_IWUSR)
    os.replace(temporary, path)


def load_dotenv(root: Path) -> None:
    for path in (root / ".env", root.parent / ".env"):
        if not path.exists():
            continue
        for raw_line in path.read_text(encoding="utf-8", errors="replace").splitlines():
            line = raw_line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            key = key.strip()
            value = value.strip().strip('"').strip("'")
            if key and key not in os.environ:
                os.environ[key] = value


def load_registry(root: Path) -> dict[str, Any]:
    configured = os.environ.get("DIGITAL_OFFICE_MODEL_PROVIDER_REGISTRY")
    path = Path(configured).expanduser() if configured else root / "model-providers.registry.json"
    value = read_json(path)
    if value.get("kind") != "digital-office-model-providers" or not isinstance(value.get("providers"), dict):
        raise GatewayError("model provider registry has an invalid shape", code="config_invalid")
    return value


def runtime_path(root: Path) -> Path:
    configured = os.environ.get("DIGITAL_OFFICE_MODEL_RUNTIME")
    return Path(configured).expanduser() if configured else root / "settings" / "model-runtime.json"


def load_runtime(root: Path) -> dict[str, Any]:
    path = runtime_path(root)
    if not path.exists():
        return {"version": "1.0.0", "kind": "digital-office-model-runtime", "default_mode": "host", "agents": {}}
    value = read_json(path)
    if value.get("kind") != "digital-office-model-runtime" or not isinstance(value.get("agents"), dict):
        raise GatewayError("model runtime configuration has an invalid shape", code="config_invalid")
    return value


def provider_settings(provider_id: str, registry: dict[str, Any]) -> dict[str, Any]:
    value = registry.get("providers", {}).get(provider_id)
    if not isinstance(value, dict):
        valid = ", ".join(sorted(registry.get("providers", {})))
        raise GatewayError(f"unknown model provider {provider_id!r}; valid providers: {valid}", code="provider_unknown")
    return value


def env_value(settings: dict[str, Any], field: str) -> str:
    name = str(settings.get(field, ""))
    return os.environ.get(name, "").strip() if name else ""


def resolve_provider(provider_id: str, registry: dict[str, Any], model: str = "") -> dict[str, Any]:
    settings = provider_settings(provider_id, registry)
    base_url = env_value(settings, "base_url_env") or str(settings.get("base_url", "")).strip()
    api_key = env_value(settings, "api_key_env")
    resolved_model = model.strip() or env_value(settings, "model_env")
    missing = []
    if not api_key:
        missing.append(str(settings.get("api_key_env", "API key")))
    if not base_url:
        missing.append(str(settings.get("base_url_env", "base URL")))
    return {
        "provider_id": provider_id,
        "display_name": settings.get("display_name", provider_id),
        "protocol": settings.get("protocol", ""),
        "base_url": base_url.rstrip("/"),
        "api_key": api_key,
        "model": resolved_model,
        "model_env": settings.get("model_env", ""),
        "api_key_env": settings.get("api_key_env", ""),
        "base_url_env": settings.get("base_url_env", ""),
        "api_version": settings.get("api_version", ""),
        "configured": not missing,
        "missing": missing,
    }


def validate_url(url: str) -> None:
    parsed = urllib.parse.urlparse(url)
    if parsed.scheme not in {"http", "https"} or not parsed.hostname:
        raise GatewayError("model API URL must be an absolute http(s) URL", code="base_url_invalid")
    if parsed.username or parsed.password:
        raise GatewayError("model API URL must not contain credentials", code="base_url_invalid")
    if parsed.scheme == "https":
        return
    host = (parsed.hostname or "").lower()
    if host not in {"localhost", "127.0.0.1", "::1"} and os.environ.get("DIGITAL_OFFICE_ALLOW_INSECURE_MODEL_API") != "1":
        raise GatewayError("plain HTTP model APIs are limited to localhost", code="insecure_base_url")


def request_spec(provider: dict[str, Any], prompt: str, system_prompt: str, max_tokens: int) -> tuple[str, dict[str, str], dict[str, Any]]:
    protocol = provider["protocol"]
    base_url = provider["base_url"]
    model = provider["model"]
    api_key = provider["api_key"]
    headers = {"Accept": "application/json", "Content-Type": "application/json", "User-Agent": "DigitalOfficeModelGateway/1.0"}
    if protocol == "openai_responses":
        headers["Authorization"] = f"Bearer {api_key}"
        body: dict[str, Any] = {"model": model, "input": prompt, "max_output_tokens": max_tokens}
        if system_prompt:
            body["instructions"] = system_prompt
        return f"{base_url}/responses", headers, body
    if protocol == "openai_chat_completions":
        headers["Authorization"] = f"Bearer {api_key}"
        messages = []
        if system_prompt:
            messages.append({"role": "system", "content": system_prompt})
        messages.append({"role": "user", "content": prompt})
        return f"{base_url}/chat/completions", headers, {"model": model, "messages": messages, "max_tokens": max_tokens}
    if protocol == "anthropic_messages":
        headers["x-api-key"] = api_key
        headers["anthropic-version"] = str(provider.get("api_version") or "2023-06-01")
        body = {"model": model, "messages": [{"role": "user", "content": prompt}], "max_tokens": max_tokens}
        if system_prompt:
            body["system"] = system_prompt
        return f"{base_url}/messages", headers, body
    if protocol == "gemini_generate_content":
        headers["x-goog-api-key"] = api_key
        body = {"contents": [{"role": "user", "parts": [{"text": prompt}]}], "generationConfig": {"maxOutputTokens": max_tokens}}
        if system_prompt:
            body["systemInstruction"] = {"parts": [{"text": system_prompt}]}
        model_path = urllib.parse.quote(model, safe="-._/")
        return f"{base_url}/models/{model_path}:generateContent", headers, body
    raise GatewayError(f"unsupported provider protocol: {protocol}", code="protocol_unsupported")


def extract_response(protocol: str, value: dict[str, Any]) -> tuple[str, dict[str, int], str]:
    if protocol == "openai_responses":
        text = str(value.get("output_text", ""))
        if not text:
            chunks = []
            for item in value.get("output", []) if isinstance(value.get("output"), list) else []:
                for part in item.get("content", []) if isinstance(item, dict) else []:
                    if isinstance(part, dict) and part.get("type") in {"output_text", "text"}:
                        chunks.append(str(part.get("text", "")))
            text = "".join(chunks)
        raw_usage = value.get("usage", {}) if isinstance(value.get("usage"), dict) else {}
        usage = {"input_tokens": int(raw_usage.get("input_tokens", 0) or 0), "output_tokens": int(raw_usage.get("output_tokens", 0) or 0)}
    elif protocol == "openai_chat_completions":
        choices = value.get("choices", [])
        text = str(choices[0].get("message", {}).get("content", "")) if isinstance(choices, list) and choices else ""
        raw_usage = value.get("usage", {}) if isinstance(value.get("usage"), dict) else {}
        usage = {"input_tokens": int(raw_usage.get("prompt_tokens", 0) or 0), "output_tokens": int(raw_usage.get("completion_tokens", 0) or 0)}
    elif protocol == "anthropic_messages":
        content = value.get("content", [])
        text = "".join(str(part.get("text", "")) for part in content if isinstance(part, dict) and part.get("type") == "text") if isinstance(content, list) else ""
        raw_usage = value.get("usage", {}) if isinstance(value.get("usage"), dict) else {}
        usage = {"input_tokens": int(raw_usage.get("input_tokens", 0) or 0), "output_tokens": int(raw_usage.get("output_tokens", 0) or 0)}
    elif protocol == "gemini_generate_content":
        candidates = value.get("candidates", [])
        parts = candidates[0].get("content", {}).get("parts", []) if isinstance(candidates, list) and candidates else []
        text = "".join(str(part.get("text", "")) for part in parts if isinstance(part, dict))
        raw_usage = value.get("usageMetadata", {}) if isinstance(value.get("usageMetadata"), dict) else {}
        usage = {"input_tokens": int(raw_usage.get("promptTokenCount", 0) or 0), "output_tokens": int(raw_usage.get("candidatesTokenCount", 0) or 0)}
    else:
        raise GatewayError(f"unsupported provider protocol: {protocol}", code="protocol_unsupported")
    if not text.strip():
        raise GatewayError("model API returned no text output", code="empty_response", status=4)
    usage["total_tokens"] = usage["input_tokens"] + usage["output_tokens"]
    return text, usage, str(value.get("id", value.get("responseId", "")))


def remote_call(url: str, headers: dict[str, str], body: dict[str, Any], *, timeout: int, attempts: int, max_response_bytes: int) -> tuple[dict[str, Any], int]:
    validate_url(url)
    encoded = json.dumps(body, ensure_ascii=False).encode("utf-8")
    last_error = ""
    for attempt in range(1, attempts + 1):
        request = urllib.request.Request(url, data=encoded, headers=headers, method="POST")
        try:
            with urllib.request.urlopen(request, timeout=timeout) as response:
                raw = response.read(max_response_bytes + 1)
                if len(raw) > max_response_bytes:
                    raise GatewayError("model API response exceeded the configured size limit", code="response_too_large", status=4)
                value = json.loads(raw.decode("utf-8"))
                if not isinstance(value, dict):
                    raise GatewayError("model API returned a non-object JSON response", code="response_invalid", status=4)
                return value, attempt
        except urllib.error.HTTPError as exc:
            raw = exc.read(16384).decode("utf-8", errors="replace")
            for value in headers.values():
                secret = value.removeprefix("Bearer ")
                if len(secret) >= 8:
                    raw = raw.replace(secret, "[REDACTED]")
            last_error = f"HTTP {exc.code}: {raw[:1000]}"
            if exc.code not in RETRYABLE_STATUS or attempt >= attempts:
                raise GatewayError(f"model API request failed: {last_error}", code="remote_http_error", status=4) from exc
        except (urllib.error.URLError, TimeoutError, socket.timeout) as exc:
            last_error = str(getattr(exc, "reason", exc))
            if attempt >= attempts:
                raise GatewayError(f"model API request failed: {last_error}", code="remote_network_error", status=4) from exc
        except json.JSONDecodeError as exc:
            raise GatewayError("model API returned invalid JSON", code="response_invalid", status=4) from exc
        time.sleep(min(2.0, 0.35 * (2 ** (attempt - 1))) + random.uniform(0.0, 0.1))
    raise GatewayError(f"model API request failed: {last_error}", code="remote_error", status=4)


def invoke(args: argparse.Namespace, registry: dict[str, Any]) -> int:
    defaults = registry.get("defaults", {})
    provider = resolve_provider(args.provider, registry, args.model or "")
    if not provider["configured"]:
        raise GatewayError(f"provider {args.provider!r} is not configured; missing: {', '.join(provider['missing'])}", code="provider_unconfigured", status=3)
    if not provider["model"]:
        raise GatewayError(f"model is required; pass --model or set {provider['model_env']}", code="model_missing", status=3)
    prompt = args.prompt if args.prompt is not None else sys.stdin.read()
    prompt = prompt.strip()
    if not prompt:
        raise GatewayError("prompt is required", code="prompt_missing")
    max_input = int(defaults.get("max_input_characters", 200000))
    if len(prompt) > max_input:
        raise GatewayError(f"prompt exceeds the {max_input} character limit", code="prompt_too_large")
    max_tokens = args.max_output_tokens or int(defaults.get("max_output_tokens", 4096))
    timeout = args.timeout or int(defaults.get("request_timeout_seconds", 120))
    url, headers, body = request_spec(provider, prompt, args.system or "", max_tokens)
    started = time.monotonic()
    value, attempts = remote_call(url, headers, body, timeout=timeout, attempts=int(defaults.get("retry_attempts", 3)), max_response_bytes=int(defaults.get("max_response_bytes", 8388608)))
    text, usage, response_id = extract_response(provider["protocol"], value)
    result = {"status": "completed", "provider": args.provider, "protocol": provider["protocol"], "model": provider["model"], "response_id": response_id, "text": text, "usage": usage, "latency_ms": round((time.monotonic() - started) * 1000), "attempts": attempts}
    print(json.dumps(result, ensure_ascii=False, indent=2, sort_keys=True) if args.json else text)
    return 0


def show_status(args: argparse.Namespace, root: Path, registry: dict[str, Any]) -> int:
    selected = [args.provider] if args.provider else sorted(registry.get("providers", {}))
    items = []
    for provider_id in selected:
        item = resolve_provider(provider_id, registry)
        items.append({key: value for key, value in item.items() if key not in {"api_key", "base_url"}} | {"base_url_configured": bool(item["base_url"])})
    payload = {"status": "ready", "providers": items, "runtime": load_runtime(root), "runtime_path": str(runtime_path(root))}
    print(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True))
    return 0


def configure(args: argparse.Namespace, root: Path, registry: dict[str, Any]) -> int:
    if not args.confirmed:
        raise GatewayError("configure requires --confirmed", code="confirmation_required")
    if args.mode == "direct_api" and (not args.provider or not args.model):
        raise GatewayError("direct_api mode requires --provider and --model", code="model_configuration_missing")
    if args.provider:
        provider_settings(args.provider, registry)
    value = load_runtime(root)
    value.setdefault("agents", {})[args.agent] = {"mode": args.mode, "provider": args.provider, "model": args.model}
    write_json_private(runtime_path(root), value)
    print(json.dumps({"status": "configured", "agent": args.agent, "runtime": value["agents"][args.agent], "secret_storage": "environment_only"}, ensure_ascii=False, indent=2, sort_keys=True))
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Direct model API gateway for Digital Office")
    sub = parser.add_subparsers(dest="command", required=True)
    p = sub.add_parser("status")
    p.add_argument("--provider")
    p = sub.add_parser("invoke")
    p.add_argument("--provider", required=True)
    p.add_argument("--model")
    p.add_argument("--prompt")
    p.add_argument("--system")
    p.add_argument("--timeout", type=int)
    p.add_argument("--max-output-tokens", type=int)
    p.add_argument("--json", action="store_true")
    p = sub.add_parser("configure")
    p.add_argument("--agent", required=True)
    p.add_argument("--mode", choices=sorted(RUNTIME_MODES), required=True)
    p.add_argument("--provider", default="")
    p.add_argument("--model", default="")
    p.add_argument("--confirmed", action="store_true")
    return parser


def main() -> int:
    root = system_root()
    load_dotenv(root)
    args = build_parser().parse_args()
    try:
        registry = load_registry(root)
        if args.command == "invoke":
            return invoke(args, registry)
        if args.command == "status":
            return show_status(args, root, registry)
        if args.command == "configure":
            return configure(args, root, registry)
        raise GatewayError(f"unknown command: {args.command}")
    except GatewayError as exc:
        print(json.dumps({"status": "error", "error": exc.code, "message": str(exc)}, ensure_ascii=False), file=sys.stderr)
        return exc.status


if __name__ == "__main__":
    raise SystemExit(main())
