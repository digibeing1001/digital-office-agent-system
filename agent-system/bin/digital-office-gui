#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SYSTEM_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
OFFICE="$SCRIPT_DIR/office-system"

HOST="127.0.0.1"
PORT="8787"
OPEN_BROWSER=1
BACKGROUND=0
QUIET=0
ROUTE="/"
TOKEN=""
PUBLIC_URL=""
USER_ID=""
ROLE=""

usage() {
  cat <<'EOF'
Usage: digital-office-gui [options]

Start the Digital Office GUI in one command.

Options:
  --host HOST          Bind address. Default: 127.0.0.1
  --port PORT          Port. Default: 8787
  --admin              Open the admin console instead of the user office
  --background         Keep the GUI server running in the background
  --no-open            Start the server without opening a browser
  --token TOKEN        Set DIGITAL_OFFICE_WEB_TOKEN for this launch
  --public-url URL     Public URL shown to the web app
  --user USER          User id passed to the GUI state API
  --role ROLE          User role passed to the GUI state API
  --quiet              Reduce server output
  -h, --help           Show this help

Examples:
  digital-office-gui
  digital-office-gui --admin
  digital-office-gui --background
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --host)
      HOST="${2:-}"
      shift 2
      ;;
    --port)
      PORT="${2:-}"
      shift 2
      ;;
    --admin)
      ROUTE="/admin"
      shift
      ;;
    --background)
      BACKGROUND=1
      shift
      ;;
    --no-open)
      OPEN_BROWSER=0
      shift
      ;;
    --token)
      TOKEN="${2:-}"
      shift 2
      ;;
    --public-url)
      PUBLIC_URL="${2:-}"
      shift 2
      ;;
    --user)
      USER_ID="${2:-}"
      shift 2
      ;;
    --role)
      ROLE="${2:-}"
      shift 2
      ;;
    --quiet)
      QUIET=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "digital-office-gui: unknown option $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [ ! -x "$OFFICE" ]; then
  echo "digital-office-gui: office-system command not found: $OFFICE" >&2
  exit 2
fi
if [ -z "$HOST" ]; then
  echo "digital-office-gui: --host cannot be empty" >&2
  exit 2
fi
if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
  echo "digital-office-gui: --port must be a number between 1 and 65535" >&2
  exit 2
fi

export DIGITAL_OFFICE_SYSTEM_HOME="${DIGITAL_OFFICE_SYSTEM_HOME:-$SYSTEM_HOME}"
if [ -n "$TOKEN" ]; then
  export DIGITAL_OFFICE_WEB_TOKEN="$TOKEN"
fi

open_host="$HOST"
case "$open_host" in
  "0.0.0.0"|"::")
    open_host="127.0.0.1"
    ;;
esac

base_url="${PUBLIC_URL:-http://$open_host:$PORT}"
base_url="${base_url%/}"
open_url="$base_url$ROUTE"
health_url="http://$open_host:$PORT/healthz"

open_browser() {
  local url="$1"
  if [ -n "${BROWSER:-}" ] && command -v "$BROWSER" >/dev/null 2>&1; then
    "$BROWSER" "$url" >/dev/null 2>&1 &
    return 0
  fi
  if command -v wslview >/dev/null 2>&1; then
    wslview "$url" >/dev/null 2>&1 &
    return 0
  fi
  if [ -n "${WSL_DISTRO_NAME:-}" ] && command -v powershell.exe >/dev/null 2>&1; then
    DIGITAL_OFFICE_GUI_URL="$url" powershell.exe -NoProfile -Command 'Start-Process $env:DIGITAL_OFFICE_GUI_URL' >/dev/null 2>&1 &
    return 0
  fi
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 &
    return 0
  fi
  if command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1 &
    return 0
  fi
  return 1
}

health_ready() {
  python3 - "$health_url" <<'PY'
import json
import sys
import urllib.request

try:
    with urllib.request.urlopen(sys.argv[1], timeout=1) as response:
        payload = json.load(response)
except Exception:
    raise SystemExit(1)
raise SystemExit(0 if payload.get("status") == "ok" else 1)
PY
}

wait_for_server() {
  local pid="${1:-}"
  local attempt
  for attempt in $(seq 1 80); do
    if health_ready >/dev/null 2>&1; then
      return 0
    fi
    if [ -n "$pid" ] && ! kill -0 "$pid" >/dev/null 2>&1; then
      return 1
    fi
    sleep 0.1
  done
  return 1
}

server_args=(web-serve --host "$HOST" --port "$PORT")
if [ -n "$PUBLIC_URL" ]; then
  server_args+=(--public-url "$PUBLIC_URL")
fi
if [ -n "$USER_ID" ]; then
  server_args+=(--user "$USER_ID")
fi
if [ -n "$ROLE" ]; then
  server_args+=(--role "$ROLE")
fi
if [ "$QUIET" -eq 1 ]; then
  server_args+=(--quiet)
fi

if health_ready >/dev/null 2>&1; then
  echo "Digital Office GUI is already running: $open_url"
  if [ "$OPEN_BROWSER" -eq 1 ]; then
    open_browser "$open_url" || echo "Open this URL in your browser: $open_url"
  fi
  exit 0
fi

if [ "$BACKGROUND" -eq 1 ]; then
  mkdir -p "$SYSTEM_HOME/logs" "$SYSTEM_HOME/tmp"
  log_file="$SYSTEM_HOME/logs/digital-office-gui.log"
  pid_file="$SYSTEM_HOME/tmp/digital-office-gui.pid"
  nohup "$OFFICE" "${server_args[@]}" >>"$log_file" 2>&1 &
  server_pid=$!
  echo "$server_pid" >"$pid_file"
  if ! wait_for_server "$server_pid"; then
    echo "digital-office-gui: server did not start. See $log_file" >&2
    exit 1
  fi
  echo "Digital Office GUI started: $open_url"
  echo "PID: $server_pid"
  echo "Log: $log_file"
  if [ "$OPEN_BROWSER" -eq 1 ]; then
    open_browser "$open_url" || echo "Open this URL in your browser: $open_url"
  fi
  exit 0
fi

"$OFFICE" "${server_args[@]}" &
server_pid=$!

cleanup() {
  if kill -0 "$server_pid" >/dev/null 2>&1; then
    kill "$server_pid" >/dev/null 2>&1 || true
    wait "$server_pid" 2>/dev/null || true
  fi
}
trap cleanup INT TERM EXIT

if ! wait_for_server "$server_pid"; then
  wait "$server_pid" 2>/dev/null || true
  echo "digital-office-gui: server did not start." >&2
  exit 1
fi

echo "Digital Office GUI: $open_url"
if [ "$OPEN_BROWSER" -eq 1 ]; then
  open_browser "$open_url" || echo "Open this URL in your browser: $open_url"
fi
wait "$server_pid"
