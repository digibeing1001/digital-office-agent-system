#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path


def root() -> Path:
    return Path(__file__).resolve().parents[1]


def read_json(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def _safe_task_id(path: Path) -> str:
    """Safely extract task_id from a harness task JSON, falling back to file stem."""
    try:
        return str(read_json(path).get("task_id", path.stem))
    except (json.JSONDecodeError, FileNotFoundError):
        return path.stem


def require(condition: bool, errors: list[str], message: str) -> None:
    if not condition:
        errors.append(message)


def main() -> int:
    base = root()
    hermes = base.parent
    errors: list[str] = []
    warnings: list[str] = []

    harness_path = base / "harness" / "production-gates.json"
    tasks_dir = base / "harness" / "tasks"
    registry_path = base / "agents.registry.json"
    digital_employees_path = base / "digital-employees.registry.json"
    workflow_packs_path = base / "workflow-packs.registry.json"
    context_envelope_path = base / "context-envelope.schema.json"
    context_handoff_policy_path = base / "context-handoff.policy.json"
    skill_installations_path = base / "skill-installations.registry.json"
    secretary_path = base / "secretary.capabilities.json"
    host_injection_path = base / "host-injection.policy.json"
    runner_path = base / "bin" / "harness-runner"
    loop_path = base / "ai-native-loop.manifest.json"
    coordination_policy_path = base / "coordination.policy.json"
    evals_dir = base / "evals"

    require(harness_path.exists(), errors, f"missing harness config: {harness_path}")
    require(tasks_dir.exists(), errors, f"missing harness tasks dir: {tasks_dir}")
    require(registry_path.exists(), errors, f"missing agents registry: {registry_path}")
    require(digital_employees_path.exists(), errors, f"missing digital employees registry: {digital_employees_path}")
    require(workflow_packs_path.exists(), errors, f"missing workflow packs registry: {workflow_packs_path}")
    require(context_envelope_path.exists(), errors, f"missing context envelope schema: {context_envelope_path}")
    require(context_handoff_policy_path.exists(), errors, f"missing context handoff policy: {context_handoff_policy_path}")
    require(skill_installations_path.exists(), errors, f"missing skill installations registry: {skill_installations_path}")
    require(not (base / "departments.registry.json").exists(), errors, "departments registry must not exist; departments are represented by digital employee Agent ownership plus Skills")
    require(secretary_path.exists(), errors, f"missing secretary capabilities: {secretary_path}")
    require(host_injection_path.exists(), errors, f"missing host injection policy: {host_injection_path}")
    require(runner_path.exists(), errors, f"missing harness runner: {runner_path}")
    require(loop_path.exists(), errors, f"missing AI native loop manifest: {loop_path}")
    require(coordination_policy_path.exists(), errors, f"missing coordination policy: {coordination_policy_path}")
    require(evals_dir.exists(), errors, f"missing evals dir: {evals_dir}")

    harness = read_json(harness_path) if harness_path.exists() else {}
    registry = read_json(registry_path) if registry_path.exists() else {}
    digital_employees = read_json(digital_employees_path) if digital_employees_path.exists() else {}
    workflow_packs = read_json(workflow_packs_path) if workflow_packs_path.exists() else {}
    context_envelope = read_json(context_envelope_path) if context_envelope_path.exists() else {}
    skill_installations = read_json(skill_installations_path) if skill_installations_path.exists() else {}
    secretary = read_json(secretary_path) if secretary_path.exists() else {}
    host_injection = read_json(host_injection_path) if host_injection_path.exists() else {}
    loop_manifest = read_json(loop_path) if loop_path.exists() else {}
    tasks = sorted(tasks_dir.glob("*.json")) if tasks_dir.exists() else []

    for role in ("product", "design", "implementation", "writing"):
        require(role in harness.get("role_gates", {}), errors, f"harness role gate missing: {role}")
    for workflow in ("pm_to_design", "pm_to_design_to_code", "ppt_production"):
        require(workflow in harness.get("workflow_gates", {}), errors, f"harness workflow gate missing: {workflow}")
    for task_id in (
        "vibe-design-production",
        "vibe-coding-production",
        "portable-routing-production",
        "ai-native-loop-production",
        "workflow-control-plane-production",
        "gui-readiness-production",
        "web-pwa-production",
        "direct-agent-invocation-production",
        "workflow-canvas-revision-production",
        "knowledge-space-acl-production",
        "role-workbench-production",
        "host-injection-production",
        "ppt-production",
        "human-judgment-gate-production",
        "collaborative-rule-intake-production",
        "runtime-replay-production",
        "multilingual-agent-eval-production",
        "digital-lawyer-production",
        "digital-employee-model-production",
        "context-envelope-production",
        "context-handoff-production",
        "backup-restore-production",
        "local-skill-installation-production",
        "ui-design-readiness-production",
    ):
        require(any(read_json(path).get("task_id") == task_id for path in tasks), errors, f"harness task missing: {task_id}")
    for stage in ("context", "decide", "act", "evaluate"):
        require(stage in loop_manifest.get("stages", {}), errors, f"AI native loop stage missing: {stage}")
    decisions = loop_manifest.get("controller", {}).get("decisions", {})
    for decision in ("continue", "replan", "retry", "wait_human", "complete", "fail", "cancel", "budget_exhausted"):
        require(decision in decisions, errors, f"loop controller decision missing: {decision}")
    hard_rules = loop_manifest.get("hard_rules", [])
    require(any("System self-modification" in rule for rule in hard_rules), errors, "loop policy must require confirmed proposals for system changes")
    require(any("Private chain-of-thought" in rule for rule in hard_rules), errors, "loop policy must forbid persisted private chain-of-thought")

    skills_root = hermes / "skills"
    required_skill_paths = {
        "vibe-coding-production-harness": skills_root / "vibe-coding-production-harness" / "SKILL.md",
        "vibe-design-production-harness": skills_root / "vibe-design-production-harness" / "SKILL.md",
    }
    for skill, path in required_skill_paths.items():
        require(path.exists(), errors, f"missing production harness skill: {skill}")

    agents = registry.get("agents", {})
    require("legal-contracts" not in agents, errors, "legacy legal-contracts Agent must not be registered")
    require("legal-compliance" not in agents, errors, "legacy legal-compliance Agent must not be registered")
    require("legal" in agents, errors, "Digital Lawyer Agent must be registered as legal")
    require(digital_employees.get("model", {}).get("levels") == ["secretary_control_plane", "digital_employee_agents", "skill_staff_lanes"], errors, "digital employee model must use secretary -> Agent -> Skill levels")
    require("legal" in digital_employees.get("employees", {}), errors, "digital employees registry missing legal")
    require(workflow_packs.get("packs", {}).get("legal", {}).get("owner_agent") == "legal", errors, "legal workflow pack must be owned by legal Agent")
    for field in ("context_id", "task_id", "context_version", "summary", "facts", "goal", "user_intent", "artifact_refs", "decisions", "omissions", "risk_flags", "context_budget", "state_hash"):
        require(field in context_envelope.get("required", []), errors, f"context envelope required field missing: {field}")
    if context_handoff_policy_path.exists():
        context_handoff = read_json(context_handoff_policy_path)
        require(context_handoff.get("default_mode") == "hybrid", errors, "context handoff default mode must be hybrid")
        require(set(context_handoff.get("acknowledgment", {}).get("decisions", [])) == {"accept", "request_context", "reject"}, errors, "context handoff acknowledgment decisions are incomplete")
    legal_install = skill_installations.get("installations", {}).get("claude-for-legal-zh", {})
    legal_install_path = base / legal_install.get("install_path", "")
    require(legal_install.get("status") == "installed_local", errors, "claude-for-legal-zh must be installed locally")
    require(legal_install_path.exists(), errors, f"missing local legal source pack: {legal_install_path}")
    require(len(list(legal_install_path.glob("**/SKILL.md"))) >= int(legal_install.get("installed_skill_files", 1)), errors, "local legal source pack does not contain the expected skill files")
    blocked_legal = skill_installations.get("installations", {}).get("Legal-Skills-Chinese", {})
    require(blocked_legal.get("status") == "blocked_license", errors, "Legal-Skills-Chinese must remain blocked until license clearance")
    require(not blocked_legal.get("used_by"), errors, "Legal-Skills-Chinese must not be active for commercial use")
    coder_skills = set(agents.get("coder", {}).get("skills", []))
    designer_skills = set(agents.get("vibe-designer", {}).get("skills", []))
    require("vibe-coding-production-harness" in coder_skills, errors, "coder missing vibe-coding-production-harness")
    require("vibe-design-production-harness" in designer_skills, errors, "vibe-designer missing vibe-design-production-harness")

    role_policy = secretary.get("routing_orchestration_policy", {})
    require("portable_roles" in role_policy, errors, "secretary missing portable role policy")
    require("role_first_rule" in role_policy, errors, "secretary missing role-first routing rule")
    require(host_injection.get("default_agent_role") == "secretary", errors, "host injection policy must inject default Agent as secretary")
    require(host_injection.get("suite_rules_authoritative_after_install") is True, errors, "host injection policy must make suite rules authoritative after install")
    if coordination_policy_path.exists():
        coordination = read_json(coordination_policy_path)
        for mode in ("single_agent", "secretary_centralized", "sequential_specialist_chain", "parallel_expert_dag", "human_gated", "debate_council"):
            require(mode in coordination.get("modes", {}), errors, f"coordination policy missing mode: {mode}")
        require("Every production run writes a hash-chained run ledger." in coordination.get("drift_controls", []), errors, "coordination policy missing ledger drift control")
    require(
        "openclaw" in host_injection.get("supported_hosts", {}),
        errors,
        "host injection policy must support OpenClaw",
    )

    router = hermes / "scripts" / "agent-router"
    if router.exists():
        proc = subprocess.run([sys.executable, str(router), "--health"], text=True, capture_output=True)
        if proc.returncode != 0:
            errors.append("agent-router health failed")
            if proc.stdout:
                warnings.append(proc.stdout.strip())
            if proc.stderr:
                warnings.append(proc.stderr.strip())
    else:
        errors.append(f"missing router: {router}")

    if runner_path.exists():
        proc = subprocess.run([sys.executable, str(runner_path), "--list"], text=True, capture_output=True)
        if proc.returncode != 0:
            errors.append("harness-runner list failed")
            if proc.stderr:
                warnings.append(proc.stderr.strip())

    result = {
        "status": "error" if errors else "ok",
        "root": str(base),
        "harness_config": harness_path.exists(),
        "harness_runner": runner_path.exists(),
        "harness_tasks": [_safe_task_id(path) for path in tasks],
        "digital_employee_model": digital_employees_path.exists(),
        "workflow_packs": workflow_packs_path.exists(),
        "context_envelope_schema": context_envelope_path.exists(),
        "skill_installations": skill_installations_path.exists(),
        "ai_native_loop_manifest": loop_path.exists(),
        "host_injection_policy": host_injection_path.exists(),
        "required_skills": {skill: path.exists() for skill, path in required_skill_paths.items()},
        "router_health": not any(error == "agent-router health failed" for error in errors),
        "errors": errors,
        "warnings": warnings,
    }
    print(json.dumps(result, ensure_ascii=False, indent=2, sort_keys=True))
    return 1 if errors else 0


if __name__ == "__main__":
    raise SystemExit(main())
