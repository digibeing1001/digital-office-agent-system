#!/usr/bin/env python3
"""Update Hermes and source-backed skills from skills.sources.json."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parent.parent


def read_json(path: Path) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def run(cmd: list[str], cwd: Path | None = None) -> tuple[int, str, str]:
    proc = subprocess.run(cmd, cwd=str(cwd) if cwd else None, text=True, capture_output=True)
    return proc.returncode, proc.stdout.strip(), proc.stderr.strip()


def rel_path(value: str) -> Path:
    return (ROOT / value).resolve()


def git_status(path: Path, branch: str | None = None) -> dict[str, Any]:
    if not (path / ".git").exists():
        return {"exists": path.exists(), "git": False, "path": str(path)}
    _, current_branch, _ = run(["git", "branch", "--show-current"], path)
    _, remote, _ = run(["git", "remote", "get-url", "origin"], path)
    _, status, _ = run(["git", "status", "--short"], path)
    behind = ""
    run(["git", "fetch", "--quiet", "origin"], path)
    if branch or current_branch:
        target = branch or current_branch
        _, behind, _ = run(["git", "rev-list", "--left-right", "--count", f"HEAD...origin/{target}"], path)
    return {
        "exists": True,
        "git": True,
        "path": str(path),
        "branch": current_branch,
        "remote": remote,
        "dirty": bool(status),
        "ahead_behind": behind,
    }


def backup(path: Path) -> Path:
    stamp = dt.datetime.now().strftime("%Y%m%d%H%M%S")
    target = ROOT / "tmp" / "update-backups" / f"{path.name}-{stamp}"
    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(path, target, ignore=shutil.ignore_patterns(".git", "__pycache__", ".venv"))
    return target


def candidate_path(path: Path) -> Path:
    stamp = dt.datetime.now().strftime("%Y%m%d%H%M%S")
    target = ROOT / "tmp" / "update-candidates" / f"{path.name}-{stamp}"
    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(path, target, ignore=shutil.ignore_patterns(".venv", "__pycache__", "node_modules"))
    return target


def update_git(entry: dict[str, Any], apply: bool, stage: bool) -> dict[str, Any]:
    path = rel_path(entry["path"])
    result = {"name": entry["name"], "type": "git", "path": str(path)}
    status = git_status(path, entry.get("branch"))
    result["status"] = status
    if not apply and not stage:
        result["action"] = "check_only"
        return result
    if not status.get("git"):
        result["action"] = "skipped_not_git"
        return result
    if status.get("dirty"):
        result["action"] = "skipped_dirty_worktree"
        return result
    if stage:
        candidate = candidate_path(path)
        code, out, err = run(["git", "pull", "--ff-only", "origin", entry.get("branch", status.get("branch") or "main")], candidate)
        result.update(
            {
                "action": "staged_candidate_pull_ff_only",
                "candidate": str(candidate),
                "returncode": code,
                "stdout": out,
                "stderr": err,
            }
        )
        return result
    if read_json(ROOT / "skills.sources.json").get("update_policy", {}).get("backup_before_update", True):
        result["backup"] = str(backup(path))
    code, out, err = run(["git", "pull", "--ff-only", "origin", entry.get("branch", status.get("branch") or "main")], path)
    result.update({"action": "pull_ff_only", "returncode": code, "stdout": out, "stderr": err})
    return result


def status_or_update(apply: bool, stage: bool) -> int:
    manifest = read_json(ROOT / "skills.sources.json")
    results: list[dict[str, Any]] = []
    hermes = manifest.get("hermes")
    if hermes:
        hermes_entry = {"name": "hermes-agent", **hermes}
        if hermes_entry.get("type") == "git":
            results.append(update_git(hermes_entry, apply, stage))
    for entry in manifest.get("sources", []):
        if entry.get("type") == "git":
            results.append(update_git(entry, apply, stage))
        else:
            results.append(
                {
                    "name": entry.get("name"),
                    "type": entry.get("type"),
                    "path": str(rel_path(entry.get("path", ""))),
                    "action": "check_only_registry_or_manual",
                    "note": "Use the skill hub installer for registry-backed skills; no direct git source is registered.",
                }
            )
    print(json.dumps({"apply": apply, "stage": stage, "results": results}, ensure_ascii=False, indent=2, sort_keys=True))
    return 0


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--apply", action="store_true")
    parser.add_argument("--stage", action="store_true")
    args = parser.parse_args()
    if args.apply and args.stage:
        print("update-system: choose either --stage or --apply, not both", file=sys.stderr)
        return 2
    return status_or_update(args.apply, args.stage)


if __name__ == "__main__":
    raise SystemExit(main())
