#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
VENV_PY="$ROOT_DIR/.venv/bin/python"

if [ -x "$VENV_PY" ]; then
  exec "$VENV_PY" "$SCRIPT_DIR/office-system.py" "$@"
fi

exec python3 "$SCRIPT_DIR/office-system.py" "$@"
