#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path
from typing import Any


def agent_system_root() -> Path:
    return Path(__file__).resolve().parents[1]


def hermes_home() -> Path:
    return agent_system_root().parent


def read_json(path: Path) -> Any:
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def resolve_path(value: str) -> Path:
    path = Path(value)
    if path.is_absolute():
        return path
    return (agent_system_root() / path).resolve()


def verify_installation(name: str, cfg: dict[str, Any]) -> dict[str, Any]:
    status = str(cfg.get("status", ""))
    if status == "blocked_license":
        return {
            "name": name,
            "status": "blocked_license",
            "ok": True,
            "reason": cfg.get("blocked_reason", ""),
            "active": False,
        }

    install_path = resolve_path(str(cfg.get("install_path", "")))
    skill_files = sorted(install_path.glob("**/SKILL.md")) if install_path.exists() else []
    min_skill_files = int(cfg.get("installed_skill_files", 1))
    required = [
        install_path / "README.md",
        install_path / "LICENSE",
    ]
    missing = [str(path) for path in required if not path.exists()]
    ok = install_path.exists() and len(skill_files) >= min_skill_files and not missing
    return {
        "name": name,
        "status": "installed_local" if ok else "error",
        "ok": ok,
        "install_path": str(install_path),
        "skill_files": len(skill_files),
        "expected_skill_files": min_skill_files,
        "missing": missing,
    }


def retry_sparse_install(cfg: dict[str, Any]) -> dict[str, Any]:
    install_path = resolve_path(str(cfg.get("install_path", "")))
    remote = str(cfg.get("remote", ""))
    if not remote:
        return {"ok": False, "error": "missing remote"}
    install_path.parent.mkdir(parents=True, exist_ok=True)
    if not (install_path / ".git").exists() and install_path.exists() and any(install_path.iterdir()):
        return {"ok": False, "error": f"{install_path} exists and is not a git sparse checkout"}
    if not install_path.exists():
        proc = subprocess.run(
            ["git", "clone", "--depth", "1", "--filter=blob:none", "--sparse", remote, str(install_path)],
            text=True,
            capture_output=True,
            timeout=300,
        )
        if proc.returncode != 0:
            return {"ok": False, "error": proc.stderr[-2000:]}
    return {"ok": True, "install_path": str(install_path)}


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--retry-missing", action="store_true")
    args = parser.parse_args()

    registry_path = agent_system_root() / "skill-installations.registry.json"
    registry = read_json(registry_path)
    results = []
    for name, cfg in registry.get("installations", {}).items():
        result = verify_installation(name, cfg)
        if not result["ok"] and args.retry_missing and cfg.get("status") == "installed_local":
            retry = retry_sparse_install(cfg)
            result = {**verify_installation(name, cfg), "retry": retry}
        results.append(result)

    payload = {
        "kind": "digital-office-skill-installation-status",
        "version": "1.0.0",
        "root": str(hermes_home()),
        "results": results,
        "status": "ok" if all(item["ok"] for item in results) else "error",
    }
    print(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True))
    return 0 if payload["status"] == "ok" else 1


if __name__ == "__main__":
    raise SystemExit(main())
