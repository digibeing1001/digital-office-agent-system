{
  "$schema": "../feishu-team.schema.json",
  "schema_version": "1.0",
  "team_id": "digital-office-research-team",
  "project_id": "project-template",
  "chat_name": "研究办公室",
  "description": "由研究秘书按课题选择专家",
  "chat_id_env": "RESEARCH_OFFICE_FEISHU_CHAT_ID",
  "secretary_agent_id": "secretary",
  "policy": {"max_hops": 6},
  "agents": [
    {"agent_id": "secretary", "display_name": "研究秘书", "profile": "office-research-secretary", "app_id_env": "RESEARCH_SECRETARY_APP_ID", "open_id_env": "RESEARCH_SECRETARY_OPEN_ID"},
    {"agent_id": "pm", "display_name": "首席研究员", "profile": "office-research-pi", "app_id_env": "RESEARCH_PI_APP_ID", "open_id_env": "RESEARCH_PI_OPEN_ID"},
    {"agent_id": "researcher", "display_name": "文献研究员", "profile": "office-literature-researcher", "app_id_env": "RESEARCH_LITERATURE_APP_ID", "open_id_env": "RESEARCH_LITERATURE_OPEN_ID"},
    {"agent_id": "planner", "display_name": "数据分析师", "profile": "office-data-analyst", "app_id_env": "RESEARCH_ANALYST_APP_ID", "open_id_env": "RESEARCH_ANALYST_OPEN_ID"},
    {"agent_id": "vibe-designer", "display_name": "研究方法专家", "profile": "office-methodologist", "app_id_env": "RESEARCH_METHOD_APP_ID", "open_id_env": "RESEARCH_METHOD_OPEN_ID"},
    {"agent_id": "coder", "display_name": "研究工程师", "profile": "office-research-engineer", "app_id_env": "RESEARCH_ENGINEER_APP_ID", "open_id_env": "RESEARCH_ENGINEER_OPEN_ID"},
    {"agent_id": "writer", "display_name": "学术写作专家", "profile": "office-academic-writer", "app_id_env": "RESEARCH_WRITER_APP_ID", "open_id_env": "RESEARCH_WRITER_OPEN_ID"},
    {"agent_id": "legal", "display_name": "研究伦理官", "profile": "office-research-ethics", "app_id_env": "RESEARCH_ETHICS_APP_ID", "open_id_env": "RESEARCH_ETHICS_OPEN_ID"}
  ]
}
