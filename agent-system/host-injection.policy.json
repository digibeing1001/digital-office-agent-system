{
  "version": "1.0.0",
  "kind": "digital-office-host-injection-policy",
  "default_agent_role": "secretary",
  "default_agent_capability_source": "SOUL.md",
  "suite_rules_authoritative_after_install": true,
  "clean_install_behavior": {
    "rule_injection": "overwrite_host_default_entrypoint",
    "requires_manual_choice": false,
    "description": "A clean host receives the Digital Office default Agent entrypoint and must load agent-system rules before host-local defaults."
  },
  "non_clean_host_behavior": {
    "requires_manual_choice": true,
    "choices": [
      {
        "id": "preserve_existing",
        "install_mode": "preserve",
        "description": "Keep existing host rules and personal runtime data active; install Digital Office side-by-side under digital-office/ for review before activation."
      },
      {
        "id": "overwrite_existing",
        "install_mode": "overwrite",
        "description": "Back up existing host entrypoint files, then replace the host default Agent entrypoint with the Digital Office secretary entrypoint."
      }
    ],
    "description": "Hosts with unmanaged rule files, user preferences, projects, knowledge, task state, or run state must not be silently overwritten."
  },
  "supported_hosts": {
    "hermes": {
      "default_target": "~/.hermes",
      "entrypoint_files": [
        "SOUL.md"
      ],
      "default_agent_injection": "SOUL.md"
    },
    "openclaw": {
      "default_target": "~/.openclaw",
      "entrypoint_files": [
        "AGENTS.md"
      ],
      "default_agent_injection": "AGENTS.md"
    },
    "generic": {
      "default_target": "~/.digital-office-agent",
      "entrypoint_files": [
        "AGENTS.md"
      ],
      "default_agent_injection": "AGENTS.md"
    }
  },
  "dirty_host_indicators": [
    "existing unmanaged SOUL.md or AGENTS.md",
    "agent-system/settings/user-preferences.md",
    "agent-system/projects entries beyond _template",
    "agent-system/knowledge/company entries",
    "agent-system/knowledge/spaces entries",
    "agent-system/rules/projects entries",
    "agent-system/tasks entries",
    "agent-system/runs entries"
  ],
  "post_install_checks": [
    "scripts/agent-router --health",
    "agent-system/bin/office-system health",
    "agent-system/bin/harness-check",
    "agent-system/bin/harness-runner --task all --no-write",
    "agent-system/bin/product-update status"
  ]
}
