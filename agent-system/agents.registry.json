{
  "version": "1.0.0",
  "kind": "portable-agent-registry",
  "description": "Canonical registry for the experimental digital-office agent team. Keep domain roles, routing rules, workflows, skills, models, and migration metadata here instead of hard-coding them in the router.",
  "portable": {
    "home_env": "HERMES_HOME",
    "registry_env": "HERMES_AGENT_REGISTRY",
    "runner_env": "HERMES_BIN",
    "target_packages": [
      "digital-office",
      "digital-law-firm",
      "digital-accounting-firm",
      "digital-media-studio"
    ],
    "rule": "A migration may change paths, credentials, profiles, skills, models, and domain vocabulary, but must not require rewriting the routing framework."
  },
  "defaults": {
    "fallback_agent": "secretary",
    "fallback_profile": "__default__",
    "fallback_model": "MiniMax-M3",
    "fallback_provider": "minimax-cn",
    "memory_policy": "keymemory",
    "notification_template": "AGENT_SWITCH: {agent} ({profile}) / model: {model} / provider: {provider} / workflow: {workflow} step {step_index}/{step_count}"
  },
  "aliases": {
    "planner": "planer",
    "designer": "vibe-designer",
    "vibe_designer": "vibe-designer",
    "research": "researcher",
    "dev": "coder",
    "developer": "coder",
    "product": "pm"
  },
  "workflows": {
    "single": {
      "label": "Single specialist",
      "steps": [
        "{primary_agent}"
      ],
      "handoff_contract": "Handle the user task inside the selected specialist boundary. Include assumptions, evidence, and next actions when relevant."
    },
    "research_then_plan": {
      "label": "Research before planning",
      "steps": [
        "researcher",
        "planer"
      ],
      "handoff_contract": "Researcher produces key assumptions, first-principles breakdown, and fact chain. Planner must base the plan on that report."
    },
    "research_then_pm": {
      "label": "Research before product decision",
      "steps": [
        "researcher",
        "pm"
      ],
      "handoff_contract": "Researcher produces the evidence base. PM turns it into product judgment, scope, risks, and decision options."
    },
    "pm_to_design": {
      "label": "Product to design",
      "steps": [
        "pm",
        "vibe-designer"
      ],
      "handoff_contract": "PM clarifies product intent and user value. Designer turns it into interaction, visual direction, and prototype guidance."
    },
    "pm_to_design_to_code": {
      "label": "Product to design to implementation",
      "steps": [
        "pm",
        "vibe-designer",
        "coder"
      ],
      "handoff_contract": "PM defines product shape, Designer creates UI direction, Coder implements or reviews the build."
    }
  },
  "agents": {
    "secretary": {
      "display_name": "Digital Office Secretary",
      "portable_role": "intake-orchestration-staffing-and-operations-advisor",
