          {"term": "plan", "weight": 4},
          {"term": "architecture", "weight": 4},
          {"term": "implementation", "weight": 4},
          {"term": "方案", "weight": 5},
          {"term": "规划", "weight": 5},
          {"term": "架构", "weight": 5},
          {"term": "怎么实现", "weight": 5}
