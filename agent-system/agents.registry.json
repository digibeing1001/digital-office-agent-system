{
  "version": "1.0.0",
  "kind": "portable-agent-registry",
  "description": "Canonical registry for the experimental digital-office agent team. Keep domain roles, routing rules, workflows, skills, models, and migration metadata here instead of hard-coding them in the router.",
  "portable": {
    "home_env": "HERMES_HOME",
    "registry_env": "HERMES_AGENT_REGISTRY",
    "runner_env": "HERMES_BIN",
    "target_packages": [
      "digital-office",
      "digital-law-firm",
      "digital-accounting-firm",
      "digital-media-studio"
    ],
    "rule": "A migration may change paths, credentials, profiles, skills, models, and domain vocabulary, but must not require rewriting the routing framework."
  },
  "defaults": {
    "fallback_agent": "secretary",
    "fallback_profile": "__default__",
    "fallback_model": "MiniMax-M3",
    "fallback_provider": "minimax-cn",
    "memory_policy": "keymemory",
    "notification_template": "AGENT_SWITCH: {agent} ({profile}) / model: {model} / provider: {provider} / workflow: {workflow} step {step_index}/{step_count}"
  },
  "routing_policy": {
    "minimum_score": 4,
    "ambiguity_margin": 2,
    "candidate_limit": 3,
    "workflow_minimum_score": 8,
    "secretary_fallback_rule": "Route to secretary when the prompt is low-confidence, ambiguous, asks for staffing/new Agent work, requires user clarification, or crosses policy/approval boundaries."
  },
  "orchestration_roles": {
    "intake": {
      "description": "Clarifies ambiguous work, handles approvals, staffing, memory/knowledge boundaries, and workflow dispatch.",
      "preferred_agents": ["secretary"]
    },
    "evidence": {
      "description": "Gathers facts, source material, market/domain evidence, comparisons, and assumptions.",
      "preferred_agents": ["researcher"]
    },
    "planning": {
      "description": "Turns intent and evidence into plans, architecture, milestones, dependencies, and feasible execution paths.",
      "preferred_agents": ["planer"]
    },
    "product": {
      "description": "Owns product judgment, requirements, prioritization, roadmap, acceptance criteria, and build/no-build decisions.",
      "preferred_agents": ["pm"]
    },
    "design": {
      "description": "Owns GUI, UX, visual direction, prototype, accessibility, and design review.",
      "preferred_agents": ["vibe-designer"]
    },
    "implementation": {
      "description": "Owns code, debugging, tests, refactoring, deployment, and technical verification.",
      "preferred_agents": ["coder"]
    },
    "writing": {
      "description": "Owns articles, posts, copywriting, editing, and publishable narrative.",
      "preferred_agents": ["writer"]
    }
  },
  "aliases": {
    "planner": "planer",
    "designer": "vibe-designer",
    "vibe_designer": "vibe-designer",
    "research": "researcher",
    "dev": "coder",
    "developer": "coder",
    "product": "pm"
  },
  "workflows": {
    "single": {
      "label": "Single specialist",
      "steps": [
        "{primary_agent}"
      ],
      "handoff_contract": "Handle the user task inside the selected specialist boundary. Include assumptions, evidence, and next actions when relevant."
    },
    "research_then_plan": {
      "label": "Research before planning",
      "steps": [
        "@role:evidence",
        "@role:planning"
      ],
      "handoff_contract": "Researcher produces key assumptions, first-principles breakdown, and fact chain. Planner must base the plan on that report."
    },
    "research_then_pm": {
      "label": "Research before product decision",
      "steps": [
        "@role:evidence",
        "@role:product"
      ],
      "handoff_contract": "Researcher produces the evidence base. PM turns it into product judgment, scope, risks, and decision options."
    },
    "pm_to_design": {
      "label": "Product to design",
      "steps": [
        "@role:product",
        "@role:design"
      ],
      "handoff_contract": "PM clarifies product intent and user value. Designer turns it into interaction, visual direction, and prototype guidance."
    },
    "pm_to_design_to_code": {
      "label": "Product to design to implementation",
      "steps": [
        "@role:product",
        "@role:design",
        "@role:implementation"
      ],
      "handoff_contract": "PM defines product shape, Designer creates UI direction, Coder implements or reviews the build."
    }
  },
  "workflow_routes": [
    {
      "workflow": "research_then_plan",
      "primary_role": "planning",
      "priority": 80,
      "minimum_score": 8,
      "reason": "The task asks for evidence gathering before a plan, architecture, or implementation path.",
      "match_all": [
        [
          {"term": "research", "weight": 5},
          {"term": "investigate", "weight": 5},
          {"term": "survey", "weight": 4},
          {"term": "调研", "weight": 6},
          {"term": "研究", "weight": 5},
