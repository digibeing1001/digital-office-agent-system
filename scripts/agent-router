#!/usr/bin/env python3
"""Portable router for the digital-office agent system.

The router is intentionally Hermes-adapter-shaped, but the routing truth lives
in ../agent-system/agents.registry.json so the same team can migrate to another
office product by changing the registry and runner adapter, not this script.
"""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Any


def discover_home() -> Path:
    configured = os.environ.get("HERMES_HOME")
    if configured:
        return Path(configured).expanduser()
    return Path(__file__).resolve().parent.parent


def registry_path(home: Path) -> Path:
    configured = os.environ.get("HERMES_AGENT_REGISTRY")
    if configured:
        return Path(configured).expanduser()
    home_registry = home / "agent-system" / "agents.registry.json"
    if home_registry.exists():
        return home_registry
    script_registry = Path(__file__).resolve().parent.parent / "agent-system" / "agents.registry.json"
    if script_registry.exists():
        return script_registry
    return home_registry


def load_registry(path: Path) -> dict[str, Any]:
    try:
        with path.open("r", encoding="utf-8") as handle:
            registry = json.load(handle)
    except FileNotFoundError:
        print(f"agent-router: registry not found: {path}", file=sys.stderr)
        raise SystemExit(2)
    except json.JSONDecodeError as exc:
        print(f"agent-router: invalid registry JSON: {path}: {exc}", file=sys.stderr)
        raise SystemExit(2)

    if not isinstance(registry.get("agents"), dict):
        print("agent-router: registry must contain an agents object", file=sys.stderr)
        raise SystemExit(2)
    custom_path = path.parent / "settings" / "custom-agents.registry.json"
    if custom_path.exists():
        try:
            with custom_path.open("r", encoding="utf-8") as handle:
                custom = json.load(handle)
            if custom.get("kind") != "digital-office-custom-agents" or not isinstance(custom.get("agents"), dict):
                raise ValueError("invalid custom Agent registry shape")
            for agent_id, record in custom["agents"].items():
                if record.get("status") == "active" and isinstance(record.get("config"), dict):
                    registry["agents"][agent_id] = record["config"]
        except (OSError, json.JSONDecodeError, ValueError) as exc:
            print(f"agent-router: invalid custom Agent registry: {custom_path}: {exc}", file=sys.stderr)
            raise SystemExit(2)
    return registry


def load_judgment_policy(home: Path) -> dict[str, Any]:
    path = home / "agent-system" / "judgment.policy.json"
    try:
        with path.open("r", encoding="utf-8") as handle:
            return json.load(handle)
    except Exception:
        return {
            "thresholds": {
                "pause_risk_score": 0.65,
                "route_low_confidence_values": ["low", "ambiguous"],
            },
            "default_options": [
                {"id": "approve_with_scope", "label": "Approve with explicit scope"},
                {"id": "request_more_evidence", "label": "Request more evidence"},
                {"id": "reject_or_stop", "label": "Reject or stop this action"},
            ],
            "hard_block_actions": [],
            "categories": [],
        }


def evaluate_judgment(prompt: str, route_info: dict[str, Any], policy: dict[str, Any]) -> dict[str, Any]:
    thresholds = policy.get("thresholds", {})
    pause_threshold = float(thresholds.get("pause_risk_score", 0.65))
    route_pause_values = {str(item) for item in thresholds.get("route_low_confidence_values", ["low", "ambiguous"])}
    risk_score = 0.0
    triggers: list[dict[str, Any]] = []
    blocked_actions: set[str] = set()
    required_roles: list[str] = []
    text = prompt.lower()
    for category in policy.get("categories", []):
        if not isinstance(category, dict):
            continue
        matched = [str(keyword) for keyword in category.get("keywords", []) if str(keyword).lower() in text]
        if not matched:
            continue
        category_score = float(category.get("risk_score", 0.0))
        risk_score = max(risk_score, category_score)
        blocked_actions.update(str(item) for item in category.get("blocked_actions", []))
        role = str(category.get("required_human_role", "project_manager"))
        if role and role not in required_roles:
            required_roles.append(role)
        triggers.append(
            {
                "type": "policy_category",
                "category": str(category.get("id", "unknown")),
                "risk_score": category_score,
                "matched_keywords": matched[:8],
                "required_human_role": role,
            }
        )
    confidence = str(route_info.get("confidence", ""))
    if route_info.get("fallback") or route_info.get("clarification_required") or confidence in route_pause_values:
        risk_score = max(risk_score, 0.72)
        blocked_actions.add("workflow_continue")
        if "project_manager" not in required_roles:
            required_roles.append("project_manager")
        triggers.append(
            {
                "type": "route_uncertainty",
                "risk_score": 0.72,
                "confidence": confidence,
                "fallback": bool(route_info.get("fallback")),
                "clarification_required": bool(route_info.get("clarification_required")),
            }
        )
    if risk_score >= 0.85:
        risk_label = "critical"
    elif risk_score >= 0.65:
        risk_label = "high"
    elif risk_score >= 0.4:
        risk_label = "medium"
    else:
        risk_label = "low"
    return {
        "version": "1.0.0",
        "kind": "digital-office-router-judgment",
        "decision": "pause" if risk_score >= pause_threshold or blocked_actions else "continue",
        "risk_score": round(risk_score, 3),
        "risk_label": risk_label,
        "required_human_role": required_roles[0] if required_roles else "project_manager",
        "required_human_roles": required_roles,
        "blocked_actions": sorted(blocked_actions),
        "triggers": triggers,
        "options": policy.get("default_options", []),
        "recommended_option": "request_more_evidence" if risk_score >= pause_threshold else "approve_with_scope",
        "prompt_sha256": hashlib.sha256(prompt.encode("utf-8")).hexdigest(),
    }


def normalize_agent_name(name: str, registry: dict[str, Any]) -> str:
    agents = registry["agents"]
    aliases = registry.get("aliases", {})
    normalized = aliases.get(name, name)
    if normalized not in agents:
        valid = ", ".join(sorted([*agents.keys(), *aliases.keys()]))
        print(f"agent-router: unknown agent '{name}'. Valid agents: {valid}", file=sys.stderr)
        raise SystemExit(2)
    return normalized


def agent_roles(name: str, cfg: dict[str, Any]) -> set[str]:
    roles = set()
    for field in ("orchestration_roles", "capability_roles", "role_tags"):
        value = cfg.get(field, [])
        if isinstance(value, str):
            roles.add(value)
        else:
            roles.update(str(item) for item in value)
    portable_role = str(cfg.get("portable_role", ""))
    if portable_role:
        roles.add(portable_role)
    roles.add(name)
    return roles


def resolve_role(role: str, registry: dict[str, Any]) -> str:
    role = str(role).strip()
    roles_cfg = registry.get("orchestration_roles", {}).get(role, {})
    candidates: list[str] = []
    for agent in roles_cfg.get("preferred_agents", []):
        candidates.append(normalize_agent_name(str(agent), registry))
    for name, cfg in registry["agents"].items():
        if role in agent_roles(name, cfg):
            candidates.append(name)
    unique_candidates = []
    for candidate in candidates:
        if candidate not in unique_candidates:
            unique_candidates.append(candidate)
    if not unique_candidates:
        print(f"agent-router: no registered Agent can fill orchestration role '{role}'", file=sys.stderr)
        raise SystemExit(2)
    unique_candidates.sort(
        key=lambda name: (
            int(registry["agents"][name].get("routing", {}).get("priority", 0)),
            name,
        ),
        reverse=True,
    )
    return unique_candidates[0]


def resolve_agent_or_role(value: Any, registry: dict[str, Any]) -> str:
    if isinstance(value, dict):
        if value.get("agent"):
            return normalize_agent_name(str(value["agent"]), registry)
        if value.get("role"):
            return resolve_role(str(value["role"]), registry)
    text = str(value)
    if text.startswith("@role:"):
        return resolve_role(text.split(":", 1)[1], registry)
    return normalize_agent_name(text, registry)


def routing_policy(registry: dict[str, Any]) -> dict[str, int]:
    policy = registry.get("routing_policy", {})
    return {
        "minimum_score": int(policy.get("minimum_score", 4)),
        "ambiguity_margin": int(policy.get("ambiguity_margin", 3)),
        "candidate_limit": int(policy.get("candidate_limit", 3)),
        "workflow_minimum_score": int(policy.get("workflow_minimum_score", 8)),
    }


def keyword_matches(prompt: str, items: list[Any]) -> tuple[int, list[dict[str, Any]]]:
    text = prompt.lower()
    score = 0
    matches: list[dict[str, Any]] = []
    for item in items:
        if isinstance(item, str):
            term = item
            weight = 1
        else:
            term = str(item.get("term", ""))
            weight = int(item.get("weight", 1))
        if term and term.lower() in text:
            score += weight
            matches.append({"term": term, "weight": weight})
    return score, matches


def keyword_score(prompt: str, cfg: dict[str, Any]) -> int:
    score, _ = keyword_matches(prompt, cfg.get("routing", {}).get("keywords", []))
    return score


def agent_score_details(prompt: str, registry: dict[str, Any]) -> dict[str, dict[str, Any]]:
    details: dict[str, dict[str, Any]] = {}
    for name, cfg in registry["agents"].items():
        score, matches = keyword_matches(prompt, cfg.get("routing", {}).get("keywords", []))
        details[name] = {"score": score, "matched_terms": matches}
    return details


def public_scores(details: dict[str, dict[str, Any]]) -> dict[str, int]:
    return {name: int(data.get("score", 0)) for name, data in details.items()}


def candidate_summary(details: dict[str, dict[str, Any]], registry: dict[str, Any], limit: int) -> list[dict[str, Any]]:
    ranked = sorted(
        details.items(),
        key=lambda item: (
            int(item[1].get("score", 0)),
            int(registry["agents"][item[0]].get("routing", {}).get("priority", 0)),
            item[0],
        ),
        reverse=True,
    )
    return [
        {
            "agent": name,
            "score": int(data.get("score", 0)),
            "matched_terms": data.get("matched_terms", []),
        }
        for name, data in ranked[:limit]
    ]


def choose_agent(prompt: str, registry: dict[str, Any]) -> tuple[str | None, dict[str, dict[str, Any]], str]:
    policy = routing_policy(registry)
    details = agent_score_details(prompt, registry)
    ranked = candidate_summary(details, registry, len(registry["agents"]))
    if not ranked or ranked[0]["score"] < policy["minimum_score"]:
        return None, details, "low_confidence"

    top = ranked[0]
    second_score = ranked[1]["score"] if len(ranked) > 1 else 0
    if second_score > 0 and top["score"] - second_score < policy["ambiguity_margin"]:
        return None, details, "ambiguous"
    return str(top["agent"]), details, "matched"


def workflow_route_score(prompt: str, route_cfg: dict[str, Any]) -> tuple[int, list[dict[str, Any]]]:
    total = 0
    matches: list[dict[str, Any]] = []
    groups = route_cfg.get("match_all", [])
    if groups:
        for group in groups:
            score, group_matches = keyword_matches(prompt, group)
            if score <= 0:
                return 0, []
            total += score
            matches.extend(group_matches)
    score, direct_matches = keyword_matches(prompt, route_cfg.get("keywords", []))
    total += score
    matches.extend(direct_matches)
    return total, matches


def choose_workflow_route(prompt: str, registry: dict[str, Any]) -> dict[str, Any] | None:
    policy = routing_policy(registry)
    matches: list[dict[str, Any]] = []
    for route_cfg in registry.get("workflow_routes", []):
        score, matched_terms = workflow_route_score(prompt, route_cfg)
        minimum = int(route_cfg.get("minimum_score", policy["workflow_minimum_score"]))
        if score >= minimum:
            item = {
                "workflow": route_cfg.get("workflow"),
                "score": score,
                "matched_terms": matched_terms,
                "reason": route_cfg.get("reason", ""),
                "priority": int(route_cfg.get("priority", 0)),
            }
            if route_cfg.get("primary_agent"):
                item["primary_agent"] = route_cfg.get("primary_agent")
            if route_cfg.get("primary_role"):
                item["primary_role"] = route_cfg.get("primary_role")
            matches.append(item)
    if not matches:
        return None
    matches.sort(key=lambda item: (item["score"], item["priority"], str(item["workflow"])), reverse=True)
    return matches[0]


def workflow_steps(agent_name: str, registry: dict[str, Any], workflow_name: str | None) -> tuple[str, list[str]]:
    agent = registry["agents"][agent_name]
    selected = workflow_name or agent.get("routing", {}).get("default_workflow", "single")
    workflow = registry.get("workflows", {}).get(selected)
    if not workflow:
        print(f"agent-router: unknown workflow '{selected}'", file=sys.stderr)
        raise SystemExit(2)

    steps: list[str] = []
    for step in workflow.get("steps", []):
        if step == "{primary_agent}":
            steps.append(normalize_agent_name(agent_name, registry))
        else:
            steps.append(resolve_agent_or_role(step, registry))
    return selected, steps


def choose_workflow(
    prompt: str,
    agent_name: str,
    registry: dict[str, Any],
    workflow_name: str | None,
    allow_workflow_routes: bool,
) -> tuple[str, list[str], dict[str, Any]]:
    if workflow_name:
        selected, steps = workflow_steps(agent_name, registry, workflow_name)
        return selected, steps, {"source": "explicit", "workflow": selected}

    selected_route = choose_workflow_route(prompt, registry) if allow_workflow_routes else None
    if selected_route and selected_route.get("workflow"):
        if selected_route.get("primary_role"):
            agent_name = resolve_role(str(selected_route["primary_role"]), registry)
            selected_route["resolved_primary_agent"] = agent_name
        elif selected_route.get("primary_agent"):
            agent_name = normalize_agent_name(str(selected_route["primary_agent"]), registry)
            selected_route["resolved_primary_agent"] = agent_name
        selected, steps = workflow_steps(agent_name, registry, str(selected_route["workflow"]))
        return selected, steps, {"source": "workflow_route", **selected_route}

    selected, steps = workflow_steps(agent_name, registry, None)
    return selected, steps, {"source": "agent_default", "workflow": selected}


def fallback_route(
    prompt: str,
    registry: dict[str, Any],
    workflow_name: str | None,
    details: dict[str, dict[str, Any]],
    reason: str,
) -> dict[str, Any]:
    defaults = registry.get("defaults", {})
    policy = routing_policy(registry)
    fallback_agent = normalize_agent_name(defaults.get("fallback_agent", "secretary"), registry)
    cfg = registry["agents"][fallback_agent]
    selected_workflow, steps = workflow_steps(fallback_agent, registry, workflow_name)
    candidates = candidate_summary(details, registry, policy["candidate_limit"])
    return {
        "matched": True,
        "fallback": True,
        "clarification_required": reason in {"low_confidence", "ambiguous"},
        "routing_reason": reason,
        "confidence": "low" if reason == "low_confidence" else "ambiguous",
        "agent": fallback_agent,
        "display_name": cfg.get("display_name", fallback_agent),
        "profile": cfg.get("profile", defaults.get("fallback_profile", "__default__")),
        "model": cfg.get("model", defaults.get("fallback_model", "MiniMax-M3")),
        "provider": cfg.get("provider", defaults.get("fallback_provider", "minimax-cn")),
        "workflow": selected_workflow,
        "workflow_reason": {"source": "secretary_fallback", "workflow": selected_workflow},
        "steps": steps,
        "scores": public_scores(details),
        "score_details": details,
        "candidates": candidates,
        "memory_policy": cfg.get("memory_policy", registry.get("defaults", {}).get("memory_policy", "keymemory")),
    }


def route(prompt: str, requested_agent: str, registry: dict[str, Any], workflow_name: str | None) -> dict[str, Any]:
    details: dict[str, dict[str, Any]] = {}
    selection_reason = "explicit_agent_requested"
    confidence = "forced"
    forced_workflow_route: dict[str, Any] | None = None
    if requested_agent == "auto":
        details = agent_score_details(prompt, registry)
        forced_workflow_route = choose_workflow_route(prompt, registry) if workflow_name is None else None
        if forced_workflow_route:
            if forced_workflow_route.get("primary_role"):
                agent_name = resolve_role(str(forced_workflow_route["primary_role"]), registry)
                forced_workflow_route["resolved_primary_agent"] = agent_name
            elif forced_workflow_route.get("primary_agent"):
                agent_name = normalize_agent_name(str(forced_workflow_route["primary_agent"]), registry)
                forced_workflow_route["resolved_primary_agent"] = agent_name
            else:
                agent_name = resolve_agent_or_role(
                    registry["workflows"][str(forced_workflow_route["workflow"])]["steps"][-1],
                    registry,
                )
                forced_workflow_route["resolved_primary_agent"] = agent_name
            selection_reason = "workflow_route"
            confidence = "workflow"
        else:
            agent_name, details, selection_reason = choose_agent(prompt, registry)
            if agent_name is None:
                return fallback_route(prompt, registry, workflow_name, details, selection_reason)
            confidence = "high"
    else:
        agent_name = normalize_agent_name(requested_agent, registry)

    assert agent_name is not None
    cfg = registry["agents"][agent_name]
    selected_workflow, steps, workflow_reason = choose_workflow(
        prompt,
        agent_name,
        registry,
        workflow_name,
        allow_workflow_routes=requested_agent == "auto" and forced_workflow_route is None,
    )
    if forced_workflow_route:
        selected_workflow, steps = workflow_steps(agent_name, registry, str(forced_workflow_route["workflow"]))
        workflow_reason = {"source": "workflow_route", **forced_workflow_route}
    if workflow_reason.get("primary_agent"):
        agent_name = normalize_agent_name(str(workflow_reason["primary_agent"]), registry)
        cfg = registry["agents"][agent_name]
    return {
        "matched": True,
        "agent": agent_name,
        "display_name": cfg.get("display_name", agent_name),
        "profile": cfg["profile"],
        "model": cfg["model"],
        "provider": cfg["provider"],
        "workflow": selected_workflow,
        "workflow_reason": workflow_reason,
        "steps": steps,
        "scores": public_scores(details),
        "score_details": details,
        "candidates": candidate_summary(details, registry, routing_policy(registry)["candidate_limit"]) if details else [],
        "routing_reason": selection_reason,
        "confidence": confidence,
        "memory_policy": cfg.get("memory_policy", registry.get("defaults", {}).get("memory_policy", "keymemory")),
    }


def append_route_log(home: Path, prompt: str, requested_agent: str, route_info: dict[str, Any]) -> None:
    if os.environ.get("DIGITAL_OFFICE_LOG_ROUTE_EVENTS", "1") in {"0", "false", "False"}:
        return
    event = {
        "time": dt.datetime.now(dt.timezone.utc).isoformat(),
        "event": "agent_route",
        "requested_agent": requested_agent,
        "matched": route_info.get("matched"),
        "fallback": route_info.get("fallback", False),
        "agent": route_info.get("agent"),
        "profile": route_info.get("profile"),
        "model": route_info.get("model"),
        "provider": route_info.get("provider"),
        "workflow": route_info.get("workflow"),
        "workflow_reason": route_info.get("workflow_reason", {}),
        "steps": route_info.get("steps", []),
        "scores": route_info.get("scores", {}),
        "routing_reason": route_info.get("routing_reason"),
        "confidence": route_info.get("confidence"),
        "judgment": route_info.get("judgment", {}),
        "clarification_required": route_info.get("clarification_required", False),
        "prompt_sha256": hashlib.sha256(prompt.encode("utf-8")).hexdigest(),
        "prompt_chars": len(prompt),
    }
    path = home / "agent-system" / "logs" / "router-events.jsonl"
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        with path.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps(event, ensure_ascii=False, sort_keys=True) + "\n")
    except Exception:
        pass


def hermes_binary() -> str:
    return (
        os.environ.get("HERMES_BIN")
        or shutil.which("hermes")
        or os.path.expanduser("~/.hermes/hermes-agent/venv/bin/hermes")
    )


def model_gateway(home: Path) -> str:
    return os.environ.get("DIGITAL_OFFICE_MODEL_GATEWAY") or str(home / "agent-system" / "bin" / "model-gateway")


def model_runtime_config(home: Path) -> dict[str, Any]:
    configured = os.environ.get("DIGITAL_OFFICE_MODEL_RUNTIME")
    path = Path(configured).expanduser() if configured else home / "agent-system" / "settings" / "model-runtime.json"
    if not path.exists():
        return {"default_mode": "host", "agents": {}}
    try:
        with path.open("r", encoding="utf-8") as handle:
            value = json.load(handle)
    except (OSError, json.JSONDecodeError) as exc:
        print(f"agent-router: invalid model runtime configuration: {path}: {exc}", file=sys.stderr)
        raise SystemExit(2)
    if value.get("kind") != "digital-office-model-runtime" or not isinstance(value.get("agents"), dict):
        print(f"agent-router: invalid model runtime configuration shape: {path}", file=sys.stderr)
        raise SystemExit(2)
    return value


def effective_runtime(home: Path, agent_name: str, cfg: dict[str, Any], requested_mode: str) -> dict[str, str]:
    runtime = model_runtime_config(home)
    override = runtime.get("agents", {}).get(agent_name, {})
    if not isinstance(override, dict):
        override = {}
    execution = cfg.get("execution", {}) if isinstance(cfg.get("execution"), dict) else {}
    mode = requested_mode or str(override.get("mode") or execution.get("mode") or runtime.get("default_mode") or "host")
    provider = str(override.get("provider") or execution.get("provider") or cfg.get("provider", ""))
    model = str(override.get("model") or execution.get("model") or cfg.get("model", ""))
    if mode == "auto":
        mode = "direct_api" if override.get("provider") and override.get("model") else "host"
    if mode not in {"host", "direct_api"}:
        print(f"agent-router: unsupported execution mode for {agent_name}: {mode}", file=sys.stderr)
        raise SystemExit(2)
    return {"mode": mode, "provider": provider, "model": model}


def skill_instruction_blocks(home: Path, cfg: dict[str, Any]) -> list[str]:
    ordered = [
        cfg.get("primary_skill"),
        *cfg.get("default_skill_chain", []),
        *cfg.get("skills", []),
    ]
    names = list(dict.fromkeys(str(item) for item in ordered if item))
    blocks: list[str] = []
    total_characters = 0
    for name in names:
        path = home / "skills" / name / "SKILL.md"
        if not path.exists():
            continue
        body = path.read_text(encoding="utf-8", errors="replace")[:18000]
        if not body.strip():
            continue
        if total_characters + len(body) > 32000:
            body = body[: max(0, 32000 - total_characters)]
        if not body:
            break
        blocks.append(f"Skill procedure: {name}\n{body}")
        total_characters += len(body)
        if len(blocks) >= 2 or total_characters >= 32000:
            break
    return blocks


def profile_system_prompt(home: Path, agent_name: str, cfg: dict[str, Any]) -> str:
    profile = str(cfg.get("profile", ""))
    candidates = []
    if profile not in {"", "default", "__default__"}:
        candidates.append(home / "profiles" / profile / "SOUL.md")
    candidates.extend([home / "SOUL.md", home / "AGENTS.md"])
    soul = ""
    for candidate in candidates:
        if candidate.exists():
            soul = candidate.read_text(encoding="utf-8", errors="replace")[:50000]
            break
    skills = [str(item) for item in cfg.get("skills", []) if str(item)]
    header = [
        f"You are the Digital Office Agent '{agent_name}'.",
        f"Role boundary: {cfg.get('portable_role', agent_name)}.",
        "Work through the supplied project context. Treat Skills as callable specialist procedures, not subordinate Agents.",
        "Preserve facts, decisions, evidence references, open questions, and acceptance criteria in every handoff.",
    ]
    if skills:
        header.append("Available Skills: " + ", ".join(skills))
    if soul:
        header.extend(["", "Profile instructions:", soul])
    skill_blocks = skill_instruction_blocks(home, cfg)
    if skill_blocks:
        header.extend(["", "Load these specialist procedures for this run only:", *skill_blocks])
    return "\n".join(header)


def switch_notice(
    registry: dict[str, Any],
    agent_name: str,
    cfg: dict[str, Any],
    workflow_name: str,
    step_index: int,
    step_count: int,
    runtime: dict[str, str] | None = None,
) -> str:
    template = registry.get("defaults", {}).get(
        "notification_template",
        "AGENT_SWITCH: {agent} ({profile}) / model: {model} / provider: {provider} / workflow: {workflow} step {step_index}/{step_count}",
    )
    active = runtime or {"provider": str(cfg["provider"]), "model": str(cfg["model"])}
    notice = template.format(
        agent=agent_name,
        profile=cfg["profile"],
        model=active["model"],
        provider=active["provider"],
        workflow=workflow_name,
        step_index=step_index,
        step_count=step_count,
    )
    return f"{notice} / runtime: {active.get('mode', 'host')}"


def prompt_for_step(
    original_prompt: str,
    registry: dict[str, Any],
    workflow_name: str,
    step_name: str,
    step_index: int,
    step_count: int,
    previous_outputs: list[str],
) -> str:
    if step_count == 1:
        return original_prompt

    workflow = registry.get("workflows", {}).get(workflow_name, {})
    agent_cfg = registry["agents"].get(step_name, {})
    decision = agent_cfg.get("decision", {})
    contract = workflow.get("handoff_contract", "")
    parts = [
        f"Workflow: {workflow.get('label', workflow_name)}",
        f"Step: {step_index}/{step_count} ({step_name})",
        f"Current Agent role: {agent_cfg.get('portable_role', step_name)}",
        f"Handoff contract: {contract}",
        "Stay inside the current Agent boundary. Do not complete later specialists' work; prepare the next specialist to do it well.",
        "",
        "Original user task:",
        original_prompt,
    ]
    use_when = decision.get("use_when", [])
    avoid_when = decision.get("avoid_when", [])
    outputs = decision.get("primary_outputs", [])
    if use_when or avoid_when or outputs:
        parts.extend(["", "Current Agent boundary:"])
        if use_when:
            parts.append("Use this Agent for: " + "; ".join(map(str, use_when)))
        if avoid_when:
            parts.append("Do not use this Agent for: " + "; ".join(map(str, avoid_when)))
        if outputs:
            parts.append("Expected outputs: " + "; ".join(map(str, outputs)))
    if previous_outputs:
        parts.extend(["", "Previous step outputs:"])
        for index, output in enumerate(previous_outputs, start=1):
            parts.extend([f"--- output {index} ---", output])
    if step_index < step_count:
        parts.extend(["", "Produce a concise handoff report for the next specialist."])
    else:
        parts.extend(["", "Produce the final user-facing answer based on the prior handoff reports."])
    return "\n".join(parts)


def run_step(prompt: str, cfg: dict[str, Any], home: Path, agent_name: str, runtime: dict[str, str]) -> subprocess.CompletedProcess[str]:
    env = os.environ.copy()
    env["HERMES_AGENT_ROUTER_BYPASS"] = "1"
    stdin_payload: str | None = None
    if runtime["mode"] == "direct_api":
        gateway = model_gateway(home)
        if not Path(gateway).exists() and not shutil.which(gateway):
            return subprocess.CompletedProcess([gateway], 2, "", f"agent-router: model gateway not found: {gateway}\n")
        cmd = [
            gateway,
            "invoke",
            "--provider",
            runtime["provider"],
            "--model",
            runtime["model"],
            "--system",
            profile_system_prompt(home, agent_name, cfg),
        ]
        stdin_payload = prompt
    else:
        cmd = [hermes_binary()]
        if cfg.get("profile") not in {"__default__", "default", ""}:
            cmd.extend(["-p", cfg["profile"]])
        cmd.extend(["-m", runtime["model"], "--provider", runtime["provider"], "-z", prompt])
    # Five minutes bounds model inference and network stalls for both adapters.
    return subprocess.run(cmd, text=True, input=stdin_payload, capture_output=True, env=env, timeout=300)


def execute_route(prompt: str, route_info: dict[str, Any], registry: dict[str, Any], home: Path, requested_mode: str) -> int:
    judgment = route_info.get("judgment", {})
    if judgment.get("decision") == "pause":
        print("HUMAN_JUDGMENT_REQUIRED: Agent dispatch paused before execution.")
        print(json.dumps(judgment, ensure_ascii=False, indent=2, sort_keys=True))
        return 4

    if not route_info["matched"]:
        print(f"AGENT_SWITCH: {route_info['agent']} / model: {route_info['model']}")
        print("No specialist route matched. Handle in secretary agent.")
        return 0

    outputs: list[str] = []
    workflow_name = route_info["workflow"]
    steps = route_info["steps"]
    for index, agent_name in enumerate(steps, start=1):
        cfg = registry["agents"][agent_name]
        runtime = effective_runtime(home, agent_name, cfg, requested_mode)
        print(switch_notice(registry, agent_name, cfg, workflow_name, index, len(steps), runtime), flush=True)
        step_prompt = prompt_for_step(prompt, registry, workflow_name, agent_name, index, len(steps), outputs)
        proc = run_step(step_prompt, cfg, home, agent_name, runtime)
        if proc.stdout:
            print(proc.stdout, end="" if proc.stdout.endswith("\n") else "\n")
            outputs.append(proc.stdout)
        if proc.stderr:
            print(proc.stderr, file=sys.stderr, end="" if proc.stderr.endswith("\n") else "\n")
        if proc.returncode != 0:
            return proc.returncode
    return 0


def print_agents(registry: dict[str, Any]) -> None:
    for name, cfg in sorted(registry["agents"].items()):
        routing = cfg.get("routing", {})
        print(
            "\t".join(
                [
                    name,
                    cfg.get("profile", ""),
                    cfg.get("model", ""),
                    cfg.get("provider", ""),
                    routing.get("default_workflow", "single"),
                    str(routing.get("priority", 0)),
                ]
            )
        )


def health_check(home: Path, registry_path_value: Path, registry: dict[str, Any]) -> int:
    errors: list[str] = []
    warnings: list[str] = []

    for name, cfg in sorted(registry["agents"].items()):
        for field in ("profile", "model", "provider"):
            if not cfg.get(field):
                errors.append(f"{name}: missing {field}")
        profile = str(cfg.get("profile", ""))
        if profile in {"__default__", "default", ""}:
            if not any((home / entrypoint).exists() for entrypoint in ("SOUL.md", "AGENTS.md")):
                errors.append(f"{name}: default secretary entrypoint not found: {home / 'SOUL.md'} or {home / 'AGENTS.md'}")
        else:
            profile_path = home / "profiles" / profile
            if not profile_path.exists():
                errors.append(f"{name}: profile not found: {profile_path}")
        if cfg.get("memory_policy") != "keymemory":
            warnings.append(f"{name}: memory_policy is {cfg.get('memory_policy')}, expected keymemory")

    for workflow_name, workflow in sorted(registry.get("workflows", {}).items()):
        for step in workflow.get("steps", []):
            if step == "{primary_agent}":
                continue
            try:
                resolve_agent_or_role(step, registry)
            except SystemExit:
                errors.append(f"{workflow_name}: unknown workflow step {step}")

    for workflow_route in registry.get("workflow_routes", []):
        workflow = workflow_route.get("workflow")
        primary_agent = workflow_route.get("primary_agent")
        primary_role = workflow_route.get("primary_role")
        if workflow not in registry.get("workflows", {}):
            errors.append(f"workflow route references unknown workflow: {workflow}")
        if primary_agent:
            try:
                normalize_agent_name(str(primary_agent), registry)
            except SystemExit:
                errors.append(f"workflow route references unknown primary_agent: {primary_agent}")
        if primary_role:
            try:
                resolve_role(str(primary_role), registry)
            except SystemExit:
                errors.append(f"workflow route references unfilled primary_role: {primary_role}")

    for test in registry.get("route_tests", []):
        prompt = test.get("prompt", "")
        expected = test.get("expect")
        result = route(prompt, "auto", registry, None)
        actual = result["agent"] if result["matched"] else None
        if actual != expected:
            errors.append(f"route test failed: {prompt!r}: expected {expected}, got {actual}")
        expected_workflow = test.get("expect_workflow")
        if expected_workflow and result.get("workflow") != expected_workflow:
            errors.append(
                f"workflow test failed: {prompt!r}: expected {expected_workflow}, got {result.get('workflow')}"
            )
        expected_steps = test.get("expect_steps")
        if expected_steps and result.get("steps") != expected_steps:
            errors.append(f"step test failed: {prompt!r}: expected {expected_steps}, got {result.get('steps')}")

    print(f"registry={registry_path_value}")
    print(f"agents={len(registry['agents'])}")
    print(f"route_tests={len(registry.get('route_tests', []))}")
    for warning in warnings:
        print(f"WARN {warning}")
    for error in errors:
        print(f"FAIL {error}")
    if not errors:
        print("OK agent-router health check passed")
    return 1 if errors else 0


def parse_args(registry: dict[str, Any]) -> argparse.Namespace:
    agents = sorted(registry["agents"].keys())
    aliases = sorted(registry.get("aliases", {}).keys())
    workflows = sorted(registry.get("workflows", {}).keys())

    parser = argparse.ArgumentParser()
    parser.add_argument("--agent", choices=["auto", *agents, *aliases], default="auto")
    parser.add_argument("--workflow", choices=workflows, default=None)
    parser.add_argument("--route-only", action="store_true")
    parser.add_argument("--route-json", action="store_true")
    parser.add_argument("--list", action="store_true")
    parser.add_argument("--health", action="store_true")
    parser.add_argument("--runtime", choices=["host", "direct_api", "auto"], default="")
    parser.add_argument("prompt", nargs="*")
    return parser.parse_args()


def main() -> int:
    home = discover_home()
    path = registry_path(home)
    registry = load_registry(path)
    judgment_policy = load_judgment_policy(home)
    args = parse_args(registry)

    if args.list:
        print_agents(registry)
        return 0

    if args.health:
        return health_check(home, path, registry)

    prompt = " ".join(args.prompt).strip() or sys.stdin.read().strip()
    if not prompt:
        print("agent-router: prompt is required", file=sys.stderr)
        return 2

    route_info = route(prompt, args.agent, registry, args.workflow)
    route_info["judgment"] = evaluate_judgment(prompt, route_info, judgment_policy)
    append_route_log(home, prompt, args.agent, route_info)

    if args.route_json:
        print(json.dumps(route_info, ensure_ascii=False, indent=2, sort_keys=True))
        return 0 if route_info["matched"] else 3

    if args.route_only:
        if not route_info["matched"]:
            return 3
        print(
            f"{route_info['agent']}\t{route_info['profile']}\t{route_info['model']}\t{route_info['provider']}"
        )
        return 0

    return execute_route(prompt, route_info, registry, home, args.runtime)


if __name__ == "__main__":
    raise SystemExit(main())
